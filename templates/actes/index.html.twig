{% extends 'base.html.twig' %}
{% block title %}Actes & Modèles - CRM Cabinet{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item active">Actes</li>
{% endblock %}
{% block content %}
<div x-data="actesPage()" x-init="init()">
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Actes &amp; Modèles</h4>
    <button class="btn btn-outline-orange" @click="showNewModele = !showNewModele"><i class="fa fa-plus me-1"></i>Nouveau modèle</button>
</div>

<!-- Formulaire édition modèle -->
<div class="card mb-3 border-warning" x-show="showEditModele" x-cloak>
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Modifier : <span style="color:var(--orange)" x-text="editingModele?.nom"></span></span>
        <button type="button" class="btn btn-sm btn-outline-secondary" @click="showEditVarsPanel = !showEditVarsPanel">
            <i class="fa fa-code me-1"></i><span x-text="showEditVarsPanel ? 'Masquer variables' : 'Variables'"></span>
        </button>
    </div>
    <div class="card-body">
        <div class="row g-2 mb-2">
            <div class="col-md-5">
                <input class="form-control form-control-sm" x-model="editData.nom" placeholder="Nom du modèle">
            </div>
            <div class="col-md-3">
                <input class="form-control form-control-sm" x-model="editData.categorie" placeholder="Catégorie">
            </div>
        </div>
        <div class="row g-2">
            <div class="col-md-3" x-show="showEditVarsPanel" x-cloak x-transition>
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="small fw-semibold">Variables disponibles</span>
                        <button class="btn btn-xs btn-outline-secondary" @click="showEditVarsPanel = false"><i class="fa fa-times"></i></button>
                    </div>
                    <div class="card-body p-2 var-panel-body">
                        <div class="small text-muted mb-2">Cliquez sur une variable pour l'insérer au curseur.</div>
                        <template x-for="groupe in variableGroups" :key="groupe.titre">
                            <div class="mb-3">
                                <div class="fw-bold mb-1" style="font-size:0.75rem;" x-text="groupe.titre"></div>
                                <template x-for="v in groupe.variables" :key="v.code">
                                    <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                                        <div style="min-width:0; font-size:0.72rem;">
                                            <span class="font-monospace flash-color" x-text="varTag(v.code)"></span>
                                            <span class="text-muted fst-italic ms-1" style="font-size:0.68rem;" x-text="v.label"></span>
                                        </div>
                                        <i class="fa fa-plus ms-2 flex-shrink-0 flash-color" @click="insererVarEdit(v.code)" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                    </div>
                                </template>
                            </div>
                        </template>
                        <div class="mt-2">
                            <div class="fw-bold mb-2" style="font-size:0.75rem;">Blocs syntaxiques</div>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fst-italic text-muted" style="font-size:0.7rem;">Conditionnel simple</span>
                                    <i class="fa fa-plus flash-color" @click="insererSnippetEdit('si')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                </div>
                            </div>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fst-italic text-muted" style="font-size:0.7rem;">Conditionnel avec sinon</span>
                                    <i class="fa fa-plus flash-color" @click="insererSnippetEdit('sinon')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                </div>
                            </div>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fst-italic text-muted" style="font-size:0.7rem;">Boucle parties adverses</span>
                                    <i class="fa fa-plus flash-color" @click="insererSnippetEdit('pour')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div :class="showEditVarsPanel ? 'col-md-9' : 'col-md-12'">
                <label class="form-label small text-muted mb-1">Contenu du modèle</label>
                <div class="d-flex flex-wrap gap-1 align-items-center px-2 py-1 border border-bottom-0 rounded-top bg-light">
                    <button type="button" class="btn btn-xs btn-outline-orange fw-bold" @click="mdActionEdit('gras')" title="Gras">G</button>
                    <button type="button" class="btn btn-xs btn-outline-orange fst-italic" @click="mdActionEdit('italique')" title="Italique">I</button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdActionEdit('h1')" title="Titre">H1</button>
                    <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdActionEdit('h2')" title="Sous-titre">H2</button>
                    <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdActionEdit('h3')" title="Paragraphe">H3</button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-xs btn-outline-orange" @click="mdActionEdit('puce')" title="Liste à puces"><i class="fa fa-list-ul"></i></button>
                    <button type="button" class="btn btn-xs btn-outline-orange" @click="mdActionEdit('num')" title="Liste numérotée"><i class="fa fa-list-ol"></i></button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdActionEdit('hr')" title="Séparateur">—</button>
                </div>
                <textarea
                    id="editModeleTextarea"
                    class="form-control font-monospace modele-textarea rounded-top-0"
                    x-model="editData.contenu"
                    rows="12"></textarea>
            </div>
        </div>
        <div class="mt-3 text-end">
            <button class="btn btn-sm btn-outline-secondary me-2" @click="showEditModele = false; editingModele = null">Annuler</button>
            <button class="btn btn-sm btn-outline-orange" @click="saveModele()"><i class="fa fa-save me-1"></i>Enregistrer les modifications</button>
        </div>
    </div>
</div>

<!-- Formulaire nouveau modèle -->
<div class="card mb-3" x-show="showNewModele" x-cloak>
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Nouveau modèle d'acte</span>
        <button type="button" class="btn btn-sm btn-outline-secondary" @click="showVarsPanel = !showVarsPanel">
            <i class="fa fa-code me-1"></i><span x-text="showVarsPanel ? 'Masquer variables' : 'Variables'"></span>
        </button>
    </div>
    <div class="card-body">
        <!-- Nom + Catégorie -->
        <div class="row g-2 mb-2">
            <div class="col-md-5">
                <input class="form-control form-control-sm" x-model="newModele.nom" placeholder="Nom du modèle (ex : Convention d'honoraires)">
            </div>
            <div class="col-md-3">
                <input class="form-control form-control-sm" x-model="newModele.categorie" placeholder="Catégorie (ex: Divorce, Contrat...)">
            </div>
        </div>

        <!-- Zone principale : palette + textarea -->
        <div class="row g-2">
            <!-- Palette de variables (collapsible) -->
            <div class="col-md-3" x-show="showVarsPanel" x-cloak x-transition>
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="small fw-semibold">Variables disponibles</span>
                        <button class="btn btn-xs btn-outline-secondary" @click="showVarsPanel = false">
                            <i class="fa fa-times"></i>
                        </button>
                    </div>
                    <div class="card-body p-2 var-panel-body">
                        <div class="small text-muted mb-2">Cliquez sur une variable pour l'insérer au curseur.</div>

                        <template x-for="groupe in variableGroups" :key="groupe.titre">
                            <div class="mb-3">
                                <div class="fw-bold mb-1" style="font-size:0.75rem;" x-text="groupe.titre"></div>
                                <template x-for="v in groupe.variables" :key="v.code">
                                    <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                                        <div style="min-width:0; font-size:0.72rem;">
                                            <span class="font-monospace flash-color" x-text="varTag(v.code)"></span>
                                            <span class="text-muted fst-italic ms-1" style="font-size:0.68rem;" x-text="v.label"></span>
                                        </div>
                                        <i class="fa fa-plus ms-2 flex-shrink-0 flash-color" @click="insererVarModele(v.code)" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                    </div>
                                </template>
                            </div>
                        </template>

                        <!-- Blocs syntaxiques -->
                        <div class="mt-2">
                            <div class="fw-bold mb-2" style="font-size:0.75rem;">Blocs syntaxiques</div>

                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fst-italic text-muted" style="font-size:0.7rem;">Conditionnel simple</span>
                                    <i class="fa fa-plus flash-color" @click="insererSnippetModele('si')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                </div>
                                <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#si variable}}
  contenu si vrai
{{/si}}{% endverbatim %}</div>
                            </div>

                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fst-italic text-muted" style="font-size:0.7rem;">Conditionnel avec sinon</span>
                                    <i class="fa fa-plus flash-color" @click="insererSnippetModele('sinon')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                </div>
                                <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#si variable}}
  contenu si vrai
{{#sinon}}
  contenu si faux
{{/si}}{% endverbatim %}</div>
                            </div>

                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fst-italic text-muted" style="font-size:0.7rem;">Boucle parties adverses</span>
                                    <i class="fa fa-plus flash-color" @click="insererSnippetModele('pour')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                </div>
                                <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#pour partie in parties_adverses}}
  {{partie.nom_complet}}
  Me {{partie.avocat}} ({{partie.barreau}})
{{/pour}}{% endverbatim %}</div>
                            </div>

                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fst-italic text-muted" style="font-size:0.7rem;">Comparaison (condition)</span>
                                    <i class="fa fa-plus flash-color" @click="insererSnippetModele('comparaison')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                                </div>
                                <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#si client_type == "Entreprise"}}
  La société {{client_intitule}}
{{#sinon}}
  {{client_civilite}} {{client_nom_complet}}
{{/si}}{% endverbatim %}</div>
                            </div>

                            <div class="mb-2">
                                <div class="fst-italic text-muted mb-1" style="font-size:0.7rem;">Variable avec filtre</div>
                                <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem;">{% verbatim %}{{client_nom | majuscule}}
{{montant | monnaie}}
{{date_complete | date_longue}}{% endverbatim %}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Textarea contenu -->
            <div :class="showVarsPanel ? 'col-md-9' : 'col-md-12'">
                <label class="form-label small text-muted mb-1">Contenu du modèle</label>
                <!-- Barre markdown -->
                <div class="d-flex flex-wrap gap-1 align-items-center px-2 py-1 border border-bottom-0 rounded-top bg-light">
                    <button type="button" class="btn btn-xs btn-outline-secondary fw-bold" @click="mdActionModele('gras')" title="Gras (**texte**)">G</button>
                    <button type="button" class="btn btn-xs btn-outline-secondary fst-italic" @click="mdActionModele('italique')" title="Italique (*texte*)">I</button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-xs btn-outline-secondary font-monospace" @click="mdActionModele('h1')" title="Titre (# ...)">H1</button>
                    <button type="button" class="btn btn-xs btn-outline-secondary font-monospace" @click="mdActionModele('h2')" title="Sous-titre (## ...)">H2</button>
                    <button type="button" class="btn btn-xs btn-outline-secondary font-monospace" @click="mdActionModele('h3')" title="Paragraphe (### ...)">H3</button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-xs btn-outline-secondary" @click="mdActionModele('puce')" title="Liste à puces"><i class="fa fa-list-ul"></i></button>
                    <button type="button" class="btn btn-xs btn-outline-secondary" @click="mdActionModele('num')" title="Liste numérotée"><i class="fa fa-list-ol"></i></button>
                    <div class="vr mx-1"></div>
                    <button type="button" class="btn btn-xs btn-outline-secondary font-monospace" @click="mdActionModele('hr')" title="Séparateur">—</button>
                    <span class="ms-auto text-muted font-monospace" style="font-size:0.62rem;"># Titre &nbsp;## Sous-titre &nbsp;### Paragraphe &nbsp;**gras** &nbsp;*italique*</span>
                </div>
                <textarea
                    id="modeleTextarea"
                    class="form-control font-monospace modele-textarea rounded-top-0"
                    x-model="newModele.contenu"
                    rows="12"
                    placeholder="Rédigez votre modèle ici...
Utilisez le panneau Variables (bouton en haut à droite) pour insérer des variables et des blocs syntaxiques."></textarea>
            </div>
        </div>

        <div class="mt-3 text-end">
            <button class="btn btn-sm btn-outline-secondary me-2" @click="showNewModele = false; showVarsPanel = false">Annuler</button>
            <button class="btn btn-sm btn-primary" @click="addModele()"><i class="fa fa-save me-1"></i>Enregistrer le modèle</button>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Bibliothèque de modèles -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Bibliothèque de modèles</div>
            <div class="list-group list-group-flush">
                <template x-if="loading">
                    <div class="list-group-item text-center py-3 text-muted fst-italic small"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</div>
                </template>
                <template x-if="!loading && modeles.length === 0">
                    <div class="list-group-item text-muted small fst-italic">Aucun modèle</div>
                </template>
                <template x-for="m in modeles" :key="m.id">
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1">
                            <div class="fw-semibold small" x-text="m.nom"></div>
                            <div class="small text-muted" x-text="m.categorie || 'Sans catégorie'"></div>
                        </div>
                        <div class="d-flex gap-3 align-items-center" style="color:#aaa; font-size:0.85rem;">
                            <i class="fa fa-gear" @click="selectModele(m)" title="Générer un acte" style="cursor:pointer;" @mouseenter="$el.style.color='#555'" @mouseleave="$el.style.color='#aaa'"></i>
                            <i class="fa fa-pencil" @click="editModele(m)" title="Modifier le modèle" style="cursor:pointer;" @mouseenter="$el.style.color='#555'" @mouseleave="$el.style.color='#aaa'"></i>
                            <i class="fa fa-trash" @click.stop="deleteModele(m.id)" title="Supprimer" style="cursor:pointer;" @mouseenter="$el.style.color='#555'" @mouseleave="$el.style.color='#aaa'"></i>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </div>

    <!-- Génération + actes récents -->
    <div class="col-md-8">
        <!-- Formulaire de génération -->
        <div class="card mb-3" x-show="selectedModele" x-cloak>
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Générer depuis : <strong x-text="selectedModele?.nom"></strong></span>
                <button class="btn btn-sm btn-outline-secondary" @click="selectedModele = null">Fermer</button>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label small">Dossier</label>
                        <select class="form-select form-select-sm" x-model="generation.dossierId">
                            <option value="">-- Sélectionner un dossier --</option>
                            <template x-for="d in dossiers" :key="d.id">
                                <option :value="d.id" x-text="d.titre"></option>
                            </template>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Nom de l'acte généré</label>
                        <input class="form-control form-control-sm" x-model="generation.nom" :placeholder="selectedModele?.nom">
                    </div>
                </div>
                <div class="mt-2 text-end">
                    <button class="btn btn-sm btn-outline-orange" @click="genererActe()" :disabled="!generation.dossierId">
                        <i class="fa fa-magic me-1"></i>Générer l'acte
                    </button>
                </div>
            </div>
        </div>

        <!-- Actes générés récents -->
        <div class="card">
            <div class="card-header">Actes générés récents</div>
            <div class="list-group list-group-flush">
                <template x-if="loading">
                    <div class="list-group-item text-center py-3 text-muted fst-italic small"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</div>
                </template>
                <template x-if="!loading && actes.length === 0">
                    <div class="list-group-item text-muted small fst-italic">Aucun acte généré</div>
                </template>
                <template x-for="a in actes" :key="a.id">
                    <div class="list-group-item d-flex align-items-center gap-2">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-semibold small" x-text="a.nom"></span>
                                <span class="badge" :style="'background:' + (statutColors[a.statut] || '#6c757d')" x-text="a.statut" style="font-size:0.65rem;color:#F8FAFC"></span>
                            </div>
                            <div class="small text-muted" x-text="new Date(a.dateGeneration).toLocaleString('fr-FR') + ' — ' + (a.dossierTitre || '—')"></div>
                        </div>
                        <div class="d-flex gap-3 align-items-center" style="color:#aaa; font-size:0.85rem;">
                            <a :href="`/actes/${a.id}`" title="Voir / Éditer" style="color:#aaa;" @mouseenter="$el.style.color='#555'" @mouseleave="$el.style.color='#aaa'"><i class="fa fa-eye"></i></a>
                            <a :href="`/api/actes-generes/${a.id}/pdf`" title="PDF" style="color:#aaa;" @mouseenter="$el.style.color='#555'" @mouseleave="$el.style.color='#aaa'"><i class="fa fa-file-pdf"></i></a>
                            <a :href="`/api/actes-generes/${a.id}/docx`" title="Word" style="color:#aaa;" @mouseenter="$el.style.color='#555'" @mouseleave="$el.style.color='#aaa'"><i class="fa fa-file-word"></i></a>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
window._statutColorsActe = {{ couleurs_statuts_acte|json_encode|raw }};
</script>
{% verbatim %}
<script>
function actesPage() {
    const VARIABLE_GROUPS = [
        {
            titre: 'Cabinet',
            variables: [
                { code: 'cabinet_nom',        label: 'Nom du cabinet' },
                { code: 'cabinet_adresse',    label: 'Adresse' },
                { code: 'cabinet_code_postal',label: 'Code postal' },
                { code: 'cabinet_ville',      label: 'Ville' },
                { code: 'cabinet_telephone',  label: 'Téléphone' },
                { code: 'cabinet_email',      label: 'Email' },
                { code: 'cabinet_siret',      label: 'SIRET' },
                { code: 'avocat_nom',         label: 'Nom de l\'avocat' },
                { code: 'avocat_barreau',     label: 'Barreau (ex: Paris)' },
                { code: 'avocat_numero',      label: 'N° ordre du barreau' },
            ]
        },
        {
            titre: 'Client',
            variables: [
                { code: 'client_civilite',    label: 'Civilité (M. / Mme)' },
                { code: 'client_nom_complet', label: 'Nom complet' },
                { code: 'client_prenom',      label: 'Prénom' },
                { code: 'client_nom',         label: 'Nom de famille' },
                { code: 'client_type',        label: 'Type (Particulier / Entreprise...)' },
                { code: 'client_intitule',    label: 'Raison sociale (entreprise)' },
                { code: 'client_siret',       label: 'SIRET client' },
                { code: 'client_email',       label: 'Email client' },
                { code: 'client_telephone',   label: 'Téléphone client' },
                { code: 'client_adresse',     label: 'Adresse client' },
                { code: 'client_ville',       label: 'Ville client' },
                { code: 'client_code_postal', label: 'Code postal client' },
            ]
        },
        {
            titre: 'Dossier',
            variables: [
                { code: 'dossier_titre',          label: 'Titre du dossier' },
                { code: 'dossier_matiere',        label: 'Matière juridique' },
                { code: 'dossier_date_ouverture', label: 'Date d\'ouverture (jj/mm/aaaa)' },
                { code: 'dossier_statut',         label: 'Statut du dossier' },
                { code: 'dossier_notes',          label: 'Notes du dossier' },
            ]
        },
        {
            titre: 'Partie adverse (principale)',
            variables: [
                { code: 'partie_adverse_nom_complet', label: 'Nom complet' },
                { code: 'partie_adverse_nom',         label: 'Nom' },
                { code: 'partie_adverse_prenom',      label: 'Prénom' },
                { code: 'partie_adverse_entreprise',  label: 'Raison sociale' },
                { code: 'partie_adverse_avocat',      label: 'Avocat adverse' },
                { code: 'partie_adverse_barreau',     label: 'Barreau adverse' },
            ]
        },
        {
            titre: 'Dates',
            variables: [
                { code: 'date_complete', label: 'Date du jour (jj/mm/aaaa)' },
                { code: 'date_longue',   label: 'Date longue (ex: 22 mai 2026)' },
                { code: 'date_jour',     label: 'Jour (jj)' },
                { code: 'date_mois',     label: 'Mois (mm)' },
                { code: 'date_annee',    label: 'Année (aaaa)' },
            ]
        }
    ];

    const SNIPPETS = {
        si:          "{{#si variable}}\n  contenu si vrai\n{{/si}}",
        sinon:       "{{#si variable}}\n  contenu si vrai\n{{#sinon}}\n  contenu si faux\n{{/si}}",
        comparaison: "{{#si client_type == \"Entreprise\"}}\n  La société {{client_intitule}}\n{{#sinon}}\n  {{client_civilite}} {{client_nom_complet}}\n{{/si}}",
        pour:        "{{#pour partie in parties_adverses}}\n  {{partie.nom_complet}} — Me {{partie.avocat}} ({{partie.barreau}})\n{{/pour}}",
    };

    return {
        modeles: [], actes: [], dossiers: [],
        loading: true,
        showNewModele: false, showVarsPanel: false,
        showEditModele: false, showEditVarsPanel: false,
        editingModele: null,
        editData: { nom: '', categorie: '', contenu: '' },
        statutColors: window._statutColorsActe,
        selectedModele: null,
        newModele: { nom: '', categorie: '', contenu: '' },
        generation: { dossierId: '', nom: '' },
        variableGroups: VARIABLE_GROUPS,

        varTag(code) { return '{{' + code + '}}'; },

        mdActionModele(type) {
            const ta = document.getElementById('modeleTextarea');
            if (!ta) return;
            const start = ta.selectionStart;
            const end   = ta.selectionEnd;
            const val   = this.newModele.contenu;
            let newVal, ns, ne;

            if (type === 'gras' || type === 'italique') {
                const m   = type === 'gras' ? '**' : '*';
                const sel = val.substring(start, end);
                if (sel) {
                    newVal = val.substring(0, start) + m + sel + m + val.substring(end);
                    ns = start + m.length; ne = end + m.length;
                } else {
                    newVal = val.substring(0, start) + m + m + val.substring(end);
                    ns = ne = start + m.length;
                }
            } else if (['h1', 'h2', 'h3', 'puce', 'num'].includes(type)) {
                const prefixes = { h1: '# ', h2: '## ', h3: '### ', puce: '- ', num: '1. ' };
                const prefix    = prefixes[type];
                const lineStart = val.lastIndexOf('\n', start - 1) + 1;
                const lineEnd   = val.indexOf('\n', start);
                const lineEnd2  = lineEnd === -1 ? val.length : lineEnd;
                const line      = val.substring(lineStart, lineEnd2);
                const clean     = line.replace(/^(#{1,3} |- |\d+\. )/, '');
                newVal = val.substring(0, lineStart) + prefix + clean + val.substring(lineEnd2);
                ns = ne = lineStart + prefix.length;
            } else if (type === 'hr') {
                const ins = '\n---\n';
                newVal = val.substring(0, start) + ins + val.substring(end);
                ns = ne = start + ins.length;
            }

            if (newVal !== undefined) {
                this.newModele.contenu = newVal;
                this.$nextTick(() => { ta.focus(); ta.setSelectionRange(ns, ne); });
            }
        },

        async init() {
            this.loading = true;
            const [m, a, d] = await Promise.all([
                api.get('/api/modeles-actes'),
                api.get('/api/actes-generes'),
                api.get('/api/dossiers?statut=' + encodeURIComponent('En cours'))
            ]);
            if (m.success) this.modeles = m.data;
            if (a.success) this.actes   = a.data;
            if (d.success) this.dossiers = d.data;
            this.loading = false;
        },

        selectModele(m) {
            this.selectedModele = m;
            this.generation.nom = m.nom;
            this.generation.dossierId = '';
        },

        insererVarModele(code) {
            const textarea = document.getElementById('modeleTextarea');
            const ins = '{{' + code + '}}';
            if (!textarea) { this.newModele.contenu += ins; return; }
            const start = textarea.selectionStart;
            const end   = textarea.selectionEnd;
            this.newModele.contenu = this.newModele.contenu.substring(0, start) + ins + this.newModele.contenu.substring(end);
            this.$nextTick(() => {
                textarea.focus();
                textarea.setSelectionRange(start + ins.length, start + ins.length);
            });
        },

        insererSnippetModele(type) {
            const textarea = document.getElementById('modeleTextarea');
            const ins = SNIPPETS[type] || '';
            if (!ins) return;
            if (!textarea) { this.newModele.contenu += ins; return; }
            const start = textarea.selectionStart;
            const end   = textarea.selectionEnd;
            this.newModele.contenu = this.newModele.contenu.substring(0, start) + ins + this.newModele.contenu.substring(end);
            this.$nextTick(() => {
                textarea.focus();
                textarea.setSelectionRange(start + ins.length, start + ins.length);
            });
        },

        editModele(m) {
            this.editingModele = m;
            this.editData = { nom: m.nom, categorie: m.categorie || '', contenu: m.contenu || '' };
            this.showEditModele = true;
            this.showNewModele = false;
            this.$nextTick(() => window.scrollTo({ top: 0, behavior: 'smooth' }));
        },

        async saveModele() {
            if (!this.editData.nom.trim()) { notify('Le nom est obligatoire', 'error'); return; }
            const data = await api.put(`/api/modeles-actes/${this.editingModele.id}`, this.editData);
            if (data.success) {
                const idx = this.modeles.findIndex(m => m.id === this.editingModele.id);
                if (idx !== -1) this.modeles.splice(idx, 1, data.data);
                this.showEditModele = false;
                this.editingModele = null;
                notify('Modèle mis à jour');
            } else {
                notify(data.error, 'error');
            }
        },

        mdActionEdit(type) {
            const ta = document.getElementById('editModeleTextarea');
            if (!ta) return;
            const start = ta.selectionStart, end = ta.selectionEnd;
            const val = this.editData.contenu;
            let newVal, ns, ne;
            if (type === 'gras' || type === 'italique') {
                const m = type === 'gras' ? '**' : '*';
                const sel = val.substring(start, end);
                if (sel) { newVal = val.substring(0, start) + m + sel + m + val.substring(end); ns = start + m.length; ne = end + m.length; }
                else { newVal = val.substring(0, start) + m + m + val.substring(end); ns = ne = start + m.length; }
            } else if (['h1','h2','h3','puce','num'].includes(type)) {
                const prefixes = { h1:'# ', h2:'## ', h3:'### ', puce:'- ', num:'1. ' };
                const prefix = prefixes[type];
                const lineStart = val.lastIndexOf('\n', start - 1) + 1;
                const lineEnd = val.indexOf('\n', start); const lineEnd2 = lineEnd === -1 ? val.length : lineEnd;
                const clean = val.substring(lineStart, lineEnd2).replace(/^(#{1,3} |- |\d+\. )/, '');
                newVal = val.substring(0, lineStart) + prefix + clean + val.substring(lineEnd2);
                ns = ne = lineStart + prefix.length;
            } else if (type === 'hr') {
                const ins = '\n---\n'; newVal = val.substring(0, start) + ins + val.substring(end); ns = ne = start + ins.length;
            }
            if (newVal !== undefined) { this.editData.contenu = newVal; this.$nextTick(() => { ta.focus(); ta.setSelectionRange(ns, ne); }); }
        },

        insererVarEdit(code) {
            const ta = document.getElementById('editModeleTextarea');
            const ins = '{{' + code + '}}';
            if (!ta) { this.editData.contenu += ins; return; }
            const start = ta.selectionStart, end = ta.selectionEnd;
            this.editData.contenu = this.editData.contenu.substring(0, start) + ins + this.editData.contenu.substring(end);
            this.$nextTick(() => { ta.focus(); ta.setSelectionRange(start + ins.length, start + ins.length); });
        },

        insererSnippetEdit(type) {
            const ta = document.getElementById('editModeleTextarea');
            const ins = SNIPPETS[type] || '';
            if (!ins) return;
            if (!ta) { this.editData.contenu += ins; return; }
            const start = ta.selectionStart, end = ta.selectionEnd;
            this.editData.contenu = this.editData.contenu.substring(0, start) + ins + this.editData.contenu.substring(end);
            this.$nextTick(() => { ta.focus(); ta.setSelectionRange(start + ins.length, start + ins.length); });
        },

        async addModele() {
            if (!this.newModele.nom.trim()) { notify('Le nom est obligatoire', 'error'); return; }
            const data = await api.post('/api/modeles-actes', this.newModele);
            if (data.success) {
                this.modeles.unshift(data.data);
                this.newModele = { nom: '', categorie: '', contenu: '' };
                this.showNewModele = false;
                this.showVarsPanel = false;
                notify('Modèle créé');
            } else {
                notify(data.error, 'error');
            }
        },

        async deleteModele(id) {
            if (!confirm('Supprimer ce modèle ?')) return;
            const data = await api.delete(`/api/modeles-actes/${id}`);
            if (data.success) {
                this.modeles = this.modeles.filter(m => m.id !== id);
                notify('Modèle supprimé');
            }
        },

        async genererActe() {
            if (!this.selectedModele) return;
            const data = await api.post('/api/actes-generes', {
                modeleId:  this.selectedModele.id,
                dossierId: this.generation.dossierId || null,
                nom:       this.generation.nom || this.selectedModele.nom
            });
            if (data.success) {
                this.actes.unshift(data.data);
                this.selectedModele = null;
                notify('Acte généré !');
            } else {
                notify(data.error, 'error');
            }
        }
    };
}
</script>
