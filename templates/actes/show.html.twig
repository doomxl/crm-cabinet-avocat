{% extends 'base.html.twig' %}
{% block title %}{{ acte.nom }} - Actes - CRM Cabinet{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item"><a href="{{ path('acte_index') }}">Actes</a></li>
<li class="breadcrumb-item active">{{ acte.nom }}</li>
{% endblock %}
{% block content %}
<div x-data="acteEditor({{ acte.id }}{% if acte.dossier %}, {{ acte.dossier.id }}{% else %}, null{% endif %}, '{{ acte.statut.value }}')" x-init="init()">

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="fw-bold mb-1"><span x-text="acteNom">{{ acte.nom }}</span></h4>
        <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
            <span class="small text-muted">Généré le {{ acte.dateGeneration|date('d/m/Y à H:i') }}</span>
            {% if acte.dossier %}
            <span class="badge bg-light text-dark border">
                <i class="fa fa-folder me-1 flash-orange"></i>{{ acte.dossier.titre|slice(0,40) }}
            </span>
            {% endif %}
            <!-- Badge statut -->
            <span class="badge" :style="'background:' + (statutColors[statut] || '#6c757d') + ';color:#F8FAFC'" x-text="statut"></span>
            <!-- Transitions -->
            <template x-if="statutConfig[statut]?.transitions.length > 0">
                <div class="dropdown">
                    <button class="btn btn-xs btn-outline-orange dropdown-toggle" data-bs-toggle="dropdown">
                        Changer le statut
                    </button>
                    <ul class="dropdown-menu dropdown-menu-sm" style="border-color:var(--orange)">
                        <template x-for="t in statutConfig[statut].transitions" :key="t">
                            <li>
                                <button class="dropdown-item small" @click="changerStatut(t)">
                                    <span class="badge me-1" :style="'background:' + (statutColors[t] || '#6c757d') + ';color:#F8FAFC'" x-text="t"></span>
                                </button>
                            </li>
                        </template>
                    </ul>
                </div>
            </template>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" @click="toggleVariables = !toggleVariables">
            <i class="fa fa-code me-1"></i>Variables
        </button>
        <button class="btn btn-sm btn-outline-orange" @click="sauvegarder()" :disabled="saving">
            <i class="fa fa-save me-1"></i><span x-text="saving ? 'Enregistrement...' : 'Enregistrer'"></span>
        </button>
        <a href="/api/actes-generes/{{ acte.id }}/pdf" class="btn btn-sm btn-outline-orange">
            <i class="fa fa-file-pdf me-1"></i>PDF
        </a>
        <a href="/api/actes-generes/{{ acte.id }}/docx" class="btn btn-sm btn-outline-orange">
            <i class="fa fa-file-word me-1"></i>Word
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Panneau Variables -->
    <div class="col-md-3" x-show="toggleVariables" x-cloak x-transition>
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="small fw-semibold">Variables disponibles</span>
                <button class="btn btn-xs btn-outline-orange" @click="toggleVariables = false">
                    <i class="fa fa-times"></i>
                </button>
            </div>
            <div class="card-body p-2" style="overflow-y:auto; max-height:680px;">
                <div class="small text-muted mb-2">Cliquez sur une variable pour l'insérer au curseur.</div>

                <template x-for="groupe in groupesVariables" :key="groupe.titre">
                    <div class="mb-3">
                        <div class="fw-bold mb-1" style="font-size:0.75rem;" x-text="groupe.titre"></div>
                        <template x-for="v in groupe.variables" :key="v.code">
                            <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                                <div style="min-width:0; font-size:0.72rem;">
                                    <span class="font-monospace flash-color" x-text="varTag(v.code)"></span>
                                    <span class="text-muted fst-italic ms-1" style="font-size:0.68rem;" x-text="v.label"></span>
                                </div>
                                <i class="fa fa-plus ms-2 flex-shrink-0 flash-color" @click="insererVariable(v.code)" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                            </div>
                        </template>
                    </div>
                </template>

                <!-- Blocs syntaxiques -->
                <div class="mt-2">
                    <div class="fw-bold mb-2" style="font-size:0.75rem;">Blocs syntaxiques</div>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fst-italic text-muted" style="font-size:0.7rem;">Conditionnel simple</span>
                            <i class="fa fa-plus flash-color" @click="insererSnippet('si')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                        </div>
                        <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#si variable}}
  contenu si vrai
{{/si}}{% endverbatim %}</div>
                    </div>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fst-italic text-muted" style="font-size:0.7rem;">Conditionnel avec sinon</span>
                            <i class="fa fa-plus flash-color" @click="insererSnippet('sinon')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                        </div>
                        <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#si variable}}
  contenu si vrai
{{#sinon}}
  contenu si faux
{{/si}}{% endverbatim %}</div>
                    </div>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fst-italic text-muted" style="font-size:0.7rem;">Boucle parties adverses</span>
                            <i class="fa fa-plus flash-color" @click="insererSnippet('pour')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                        </div>
                        <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#pour partie in parties_adverses}}
  {{partie.nom_complet}}
  Me {{partie.avocat}} ({{partie.barreau}})
{{/pour}}{% endverbatim %}</div>
                    </div>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fst-italic text-muted" style="font-size:0.7rem;">Comparaison (condition)</span>
                            <i class="fa fa-plus flash-color" @click="insererSnippet('comparaison')" title="Insérer" style="cursor:pointer; font-size:0.65rem;"></i>
                        </div>
                        <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem; white-space:pre;">{% verbatim %}{{#si client_type == "Entreprise"}}
  La société {{client_intitule}}
{{#sinon}}
  {{client_civilite}} {{client_nom_complet}}
{{/si}}{% endverbatim %}</div>
                    </div>

                    <div class="mb-2">
                        <div class="fst-italic text-muted mb-1" style="font-size:0.7rem;">Variable avec filtre</div>
                        <div class="p-2 bg-light rounded font-monospace flash-color" style="font-size:0.7rem;">{% verbatim %}{{client_nom | majuscule}}
{{montant | monnaie}}
{{date_complete | date_longue}}{% endverbatim %}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Éditeur principal -->
    <div :class="toggleVariables ? 'col-md-9' : 'col-md-12'">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="small fw-semibold">Contenu de l'acte</span>
                <div class="d-flex gap-2 align-items-center">
                    <span class="small text-muted" x-text="compteurMots + ' mots'"></span>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-orange" :class="modeAffichage === 'editeur' ? 'active' : ''" @click="modeAffichage = 'editeur'">
                            <i class="fa fa-edit me-1"></i>Éditeur
                        </button>
                        <button class="btn btn-outline-orange" :class="modeAffichage === 'apercu' ? 'active' : ''" @click="basculerApercu()">
                            <i class="fa fa-eye me-1"></i>Aperçu
                        </button>
                    </div>
                </div>
            </div>
            <!-- Barre markdown -->
            <div class="d-flex flex-wrap gap-1 align-items-center px-3 py-2 border-bottom bg-light" x-show="modeAffichage === 'editeur'">
                <button type="button" class="btn btn-xs btn-outline-orange fw-bold" @click="mdAction('gras')" title="Gras (**texte**)">G</button>
                <button type="button" class="btn btn-xs btn-outline-orange fst-italic" @click="mdAction('italique')" title="Italique (*texte*)">I</button>
                <div class="vr mx-1"></div>
                <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdAction('h1')" title="Titre (# ...)">H1</button>
                <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdAction('h2')" title="Sous-titre (## ...)">H2</button>
                <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdAction('h3')" title="Paragraphe (### ...)">H3</button>
                <div class="vr mx-1"></div>
                <button type="button" class="btn btn-xs btn-outline-orange" @click="mdAction('puce')" title="Liste à puces (- item)"><i class="fa fa-list-ul"></i></button>
                <button type="button" class="btn btn-xs btn-outline-orange" @click="mdAction('num')" title="Liste numérotée (1. item)"><i class="fa fa-list-ol"></i></button>
                <div class="vr mx-1"></div>
                <button type="button" class="btn btn-xs btn-outline-orange font-monospace" @click="mdAction('hr')" title="Séparateur (---)">—</button>
                <span class="ms-auto text-muted font-monospace" style="font-size:0.62rem;"># Titre &nbsp;## Sous-titre &nbsp;### Paragraphe &nbsp;**gras** &nbsp;*italique*</span>
            </div>

            <div class="card-body p-0">
                <!-- Mode éditeur -->
                <div x-show="modeAffichage === 'editeur'">
                    <textarea
                        id="acteTextarea"
                        class="form-control border-0 font-monospace modele-textarea rounded-0"
                        x-model="contenu"
                        @input="onContenuChange()"
                        rows="30"
                        placeholder="Contenu de l'acte..."></textarea>
                </div>
                <!-- Mode aperçu -->
                <div x-show="modeAffichage === 'apercu'" x-cloak class="p-4 apercu-container">
                    <div x-show="apercuChargement" class="text-center text-muted py-5">
                        <i class="fa fa-spinner fa-spin fa-2x mb-2"></i>
                        <p>Génération de l'aperçu...</p>
                    </div>
                    <div x-show="!apercuChargement && apercuHtml !== ''" x-html="apercuHtml" class="acte-apercu"></div>
                    <div x-show="!apercuChargement && apercuHtml === ''" class="text-center text-muted py-5">
                        <i class="fa fa-eye fa-2x mb-2"></i>
                        <p>Aucun contenu à afficher</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Métadonnées -->
        <div class="card mt-3">
            <div class="card-header small fw-semibold">Métadonnées</div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-8">
                        <label class="form-label small">Nom de l'acte</label>
                        <input class="form-control form-control-sm" x-model="acteNom" placeholder="Nom de l'acte">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Dossier associé</label>
                        <div class="form-control form-control-sm bg-light">
                            {% if acte.dossier %}
                                <a href="/dossiers/{{ acte.dossier.id }}" class="text-decoration-none">
                                    {{ acte.dossier.titre|slice(0,40) }}
                                </a>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function acteEditor(acteId, dossierId, statutInitial) {
    return {
        acteId,
        dossierId,
        acteNom: '{{ acte.nom|escape('js') }}',
        contenu: '',
        apercuHtml: '',
        apercuChargement: false,
        modeAffichage: 'editeur',
        toggleVariables: false,
        saving: false,
        compteurMots: 0,
        statut: statutInitial || 'Brouillon',

        statutColors: {{ couleurs_statuts_acte|json_encode|raw }},

        statutConfig: {
            'Brouillon':   { transitions: ['En révision', 'Validé'] },
            'En révision': { transitions: ['Validé', 'Brouillon'] },
            'Validé':      { transitions: ['Signé', 'En révision'] },
            'Signé':       { transitions: ['Archivé'] },
            'Archivé':     { transitions: [] },
        },

        groupesVariables: [
            {
                titre: 'Cabinet',
                variables: [
                    { code: 'cabinet_nom',         label: 'Nom du cabinet' },
                    { code: 'cabinet_adresse',      label: 'Adresse' },
                    { code: 'cabinet_code_postal',  label: 'Code postal' },
                    { code: 'cabinet_ville',        label: 'Ville' },
                    { code: 'cabinet_telephone',    label: 'Téléphone' },
                    { code: 'cabinet_email',        label: 'Email' },
                    { code: 'cabinet_siret',        label: 'SIRET' },
                    { code: 'avocat_nom',           label: 'Nom de l\'avocat' },
                    { code: 'avocat_barreau',       label: 'Barreau (ex: Paris)' },
                    { code: 'avocat_numero',        label: 'N° ordre du barreau' },
                ]
            },
            {
                titre: 'Client',
                variables: [
                    { code: 'client_civilite',      label: 'Civilité (M. / Mme)' },
                    { code: 'client_nom_complet',   label: 'Nom complet' },
                    { code: 'client_prenom',        label: 'Prénom' },
                    { code: 'client_nom',           label: 'Nom de famille' },
                    { code: 'client_type',          label: 'Type (Particulier / Entreprise...)' },
                    { code: 'client_intitule',      label: 'Raison sociale (entreprise)' },
                    { code: 'client_siret',         label: 'SIRET client' },
                    { code: 'client_email',         label: 'Email client' },
                    { code: 'client_telephone',     label: 'Téléphone client' },
                    { code: 'client_adresse',       label: 'Adresse client' },
                    { code: 'client_ville',         label: 'Ville client' },
                    { code: 'client_code_postal',   label: 'Code postal client' },
                ]
            },
            {
                titre: 'Dossier',
                variables: [
                    { code: 'dossier_titre',          label: 'Titre du dossier' },
                    { code: 'dossier_matiere',        label: 'Matière juridique' },
                    { code: 'dossier_date_ouverture', label: 'Date d\'ouverture (jj/mm/aaaa)' },
                    { code: 'dossier_statut',         label: 'Statut du dossier' },
                    { code: 'dossier_notes',          label: 'Notes du dossier' },
                ]
            },
            {
                titre: 'Partie adverse (principale)',
                variables: [
                    { code: 'partie_adverse_nom_complet', label: 'Nom complet' },
                    { code: 'partie_adverse_nom',         label: 'Nom' },
                    { code: 'partie_adverse_prenom',      label: 'Prénom' },
                    { code: 'partie_adverse_entreprise',  label: 'Raison sociale' },
                    { code: 'partie_adverse_avocat',      label: 'Avocat adverse' },
                    { code: 'partie_adverse_barreau',     label: 'Barreau adverse' },
                ]
            },
            {
                titre: 'Dates',
                variables: [
                    { code: 'date_complete',  label: 'Date du jour (jj/mm/aaaa)' },
                    { code: 'date_longue',    label: 'Date longue (ex: 22 mai 2026)' },
                    { code: 'date_jour',      label: 'Jour (jj)' },
                    { code: 'date_mois',      label: 'Mois (mm)' },
                    { code: 'date_annee',     label: 'Année (aaaa)' },
                ]
            }
        ],

        varTag(code) { return '\x7B\x7B' + code + '\x7D\x7D'; },

        mdAction(type) {
            const ta = document.getElementById('acteTextarea');
            if (!ta) return;
            const start = ta.selectionStart;
            const end   = ta.selectionEnd;
            const val   = this.contenu;
            let newVal, ns, ne;

            if (type === 'gras' || type === 'italique') {
                const m   = type === 'gras' ? '**' : '*';
                const sel = val.substring(start, end);
                if (sel) {
                    newVal = val.substring(0, start) + m + sel + m + val.substring(end);
                    ns = start + m.length; ne = end + m.length;
                } else {
                    newVal = val.substring(0, start) + m + m + val.substring(end);
                    ns = ne = start + m.length;
                }
            } else if (['h1', 'h2', 'h3', 'puce', 'num'].includes(type)) {
                const prefixes = { h1: '# ', h2: '## ', h3: '### ', puce: '- ', num: '1. ' };
                const prefix   = prefixes[type];
                const lineStart = val.lastIndexOf('\n', start - 1) + 1;
                const lineEnd   = val.indexOf('\n', start);
                const lineEnd2  = lineEnd === -1 ? val.length : lineEnd;
                const line      = val.substring(lineStart, lineEnd2);
                const clean     = line.replace(/^(#{1,3} |- |\d+\. )/, '');
                newVal = val.substring(0, lineStart) + prefix + clean + val.substring(lineEnd2);
                ns = ne = lineStart + prefix.length;
            } else if (type === 'hr') {
                const ins = '\n---\n';
                newVal = val.substring(0, start) + ins + val.substring(end);
                ns = ne = start + ins.length;
            }

            if (newVal !== undefined) {
                this.contenu = newVal;
                this.onContenuChange();
                this.$nextTick(() => { ta.focus(); ta.setSelectionRange(ns, ne); });
            }
        },

        snippets: {% verbatim %}{
            si:          "{{#si variable}}\n  contenu si vrai\n{{/si}}",
            sinon:       "{{#si variable}}\n  contenu si vrai\n{{#sinon}}\n  contenu si faux\n{{/si}}",
            pour:        "{{#pour partie in parties_adverses}}\n  {{partie.nom_complet}} — Me {{partie.avocat}} ({{partie.barreau}})\n{{/pour}}",
            comparaison: "{{#si client_type == \"Entreprise\"}}\n  La société {{client_intitule}}\n{{#sinon}}\n  {{client_civilite}} {{client_nom_complet}}\n{{/si}}",
        }{% endverbatim %},

        async init() {
            const data = await api.get(`/api/actes-generes/${this.acteId}`);
            if (data.success) {
                this.contenu = data.data.contenu || '';
                this.acteNom = data.data.nom || this.acteNom;
                this.onContenuChange();
            }
        },

        onContenuChange() {
            const texte = this.contenu.replace(/\{\{.*?\}\}/gs, '').trim();
            this.compteurMots = texte ? texte.split(/\s+/).filter(Boolean).length : 0;
        },

        insererVariable(code) {
            const textarea = document.getElementById('acteTextarea');
            if (!textarea) return;
            const start = textarea.selectionStart;
            const end   = textarea.selectionEnd;
            const ins   = '\x7B\x7B' + code + '\x7D\x7D';
            this.contenu = this.contenu.substring(0, start) + ins + this.contenu.substring(end);
            this.$nextTick(() => {
                textarea.focus();
                textarea.setSelectionRange(start + ins.length, start + ins.length);
            });
            this.onContenuChange();
        },

        insererSnippet(type) {
            const textarea = document.getElementById('acteTextarea');
            const ins = this.snippets[type] || '';
            if (!ins) return;
            if (!textarea) { this.contenu += ins; return; }
            const start = textarea.selectionStart;
            const end   = textarea.selectionEnd;
            this.contenu = this.contenu.substring(0, start) + ins + this.contenu.substring(end);
            this.$nextTick(() => {
                textarea.focus();
                textarea.setSelectionRange(start + ins.length, start + ins.length);
            });
            this.onContenuChange();
        },

        async basculerApercu() {
            this.modeAffichage = 'apercu';
            await this.genererApercu();
        },

        async genererApercu() {
            this.apercuChargement = true;
            this.apercuHtml = '';

            if (this.dossierId) {
                // Résolution réelle côté serveur avec les données du dossier
                const resp = await api.post('/api/actes-generes/preview', {
                    contenu: this.contenu,
                    dossierId: this.dossierId
                });
                if (resp.success) {
                    this.apercuHtml = resp.contenu;
                    this.apercuChargement = false;
                    return;
                }
            }

            // Aperçu client-side : met en surbrillance les variables non résolues
            {% verbatim %}
            let html = this.contenu
                .replace(/\{\{#pour\s+\w+\s+in\s+[\w.]+\}\}([\s\S]*?)\{\{\/pour\}\}/g, (_, inner) =>
                    `<span class="bloc-conditionnel" style="border-color:#10b981;">🔁 boucle : ${inner.trim()}</span>`)
                .replace(/\{\{#si\s+([^}]+?)\}\}([\s\S]*?)(?:\{\{#sinon\}\}([\s\S]*?))?\{\{\/si\}\}/g, (_, cond, vrai, faux) => {
                    const faussePartie = faux ? `<br><em style="color:#6b7280;">sinon : ${faux.trim()}</em>` : '';
                    return `<span class="bloc-conditionnel">si ${cond.trim()} : ${vrai.trim()}${faussePartie}</span>`;
                })
                .replace(/\{\{([\w.|]+)\}\}/g, match => `<span class="var-unresolved">${match}</span>`)
                // Markdown basique
                .replace(/^# (.+)$/gm,  '<h2>$1</h2>')
                .replace(/^## (.+)$/gm, '<h3>$1</h3>')
                .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.+?)\*/g,    '<em>$1</em>')
                .replace(/^---+$/gm, '<hr>')
                .replace(/\n/g, '<br>');
            this.apercuHtml = html;
            {% endverbatim %}
            this.apercuChargement = false;
        },

        async changerStatut(nouveau) {
            const data = await api.patch(`/api/actes-generes/${this.acteId}/statut`, { statut: nouveau });
            if (data.success) {
                this.statut = data.data.statut;
                notify(`Statut : ${this.statut}`);
            } else {
                notify(data.error || 'Erreur', 'error');
            }
        },

        async sauvegarder() {
            this.saving = true;
            try {
                const data = await api.put(`/api/actes-generes/${this.acteId}`, {
                    nom: this.acteNom,
                    contenu: this.contenu
                });
                if (data.success) {
                    notify('Acte enregistré');
                } else {
                    notify(data.error || 'Erreur lors de la sauvegarde', 'error');
                }
            } catch(e) {
                notify('Erreur réseau', 'error');
            }
            this.saving = false;
        }
    };
}
</script>
{% endblock %}
