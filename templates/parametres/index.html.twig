        reinitialiserEcheances() {
            this.niveauxEcheance = this.niveauxEcheance.map(n => ({ ...n, couleur: n.defaut }));
            notify('Couleurs réinitialisées — cliquez sur Enregistrer pour confirmer', 'info');
        },

        async sauvegarderEcheances() {
            this.savingEcheance = true;
            const couleursEcheance = {};
