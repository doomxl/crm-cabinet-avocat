{% extends 'base.html.twig' %}
{% block title %}Gestion du temps - CRM Cabinet{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item active">Temps</li>
{% endblock %}
{% block content %}
<div x-data="gestionTemps({{ tauxHoraireDefaut }}, {{ sessionEnCours ? sessionEnCours.id : 'null' }})" x-init="init()">
<h4 class="mb-4 fw-bold">Gestion du temps</h4>

<!-- Chrono actif -->
<div class="card mb-4" :class="sessionActive ? 'border-2' : ''" :style="sessionActive ? 'border-color:var(--orange)' : ''">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="fa fa-circle-dot me-2" :class="sessionActive ? 'animate__animated animate__flash' : 'text-muted'" :style="sessionActive ? 'color:var(--orange)' : ''"></i>
        <span x-text="sessionActive ? 'Session en cours' : 'Démarrer une session'"></span></span>
        <span class="badge bg-transparent border fs-5 font-monospace" style="border-color:var(--orange);color:var(--orange)" x-show="sessionActive" x-text="formatDuree(elapsed)"></span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label small">Client</label>
                <select class="form-select" x-model="newSession.clientId" :disabled="sessionActive" @change="onClientChange()">
                    <option value="">-- Aucun --</option>
                    {% for client in clients %}
                    <option value="{{ client.id }}">{{ client.nomComplet }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small">Dossier</label>
                <select class="form-select" x-model="newSession.dossierId" :disabled="sessionActive" @change="onDossierChange()">
                    <option value="">-- Aucun --</option>
                    <template x-for="d in filteredDossiers" :key="d.id">
                        <option :value="String(d.id)" x-text="d.titre"></option>
                    </template>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Taux horaire (€/h)</label>
                <input type="number" class="form-control" x-model="newSession.tauxHoraire" :disabled="sessionActive" step="5">
            </div>
            <div class="col-md-2">
                <label class="form-label small d-block">&nbsp;</label>
                <button x-show="!sessionActive" x-cloak class="btn btn-outline-orange w-100" @click="demarrer()">
                    <i class="fa fa-play me-1"></i>Démarrer
                </button>
                <button x-show="sessionActive" x-cloak class="btn btn-orange w-100" @click="arreter()">
                    <i class="fa fa-stop me-1"></i>Arrêter
                </button>
            </div>
            <div class="col-12" x-show="!sessionActive">
                <input type="text" class="form-control" x-model="newSession.description" placeholder="Description de la tâche...">
            </div>
        </div>
        <div class="mt-3" x-show="sessionActive && elapsed > 0">
            <div class="small text-muted">Montant estimé :
                <strong style="color:var(--orange)" x-text="(elapsed/3600 * newSession.tauxHoraire).toLocaleString('fr-FR', {style:'currency',currency:'EUR'})"></strong>
            </div>
        </div>
    </div>
</div>

<!-- Journal des sessions -->
<div class="card">
    <div class="card-header"><i class="fa fa-history me-2"></i>Journal des sessions</div>
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr><th>Début</th><th>Fin</th><th>Durée</th><th>Dossier</th><th>Taux</th><th>Montant</th><th>Description</th><th></th></tr>
            </thead>
            <tbody>
                <template x-if="loading">
                    <tr><td colspan="8" class="text-center py-4 text-muted fst-italic small"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</td></tr>
                </template>
                <template x-if="!loading && sessions.length === 0">
                    <tr><td colspan="8" class="text-center py-4 text-muted fst-italic">Aucune session enregistrée</td></tr>
                </template>
                <template x-for="s in sessions" :key="s.id">
                    <tr>
                        <td class="small" x-text="new Date(s.debut).toLocaleString('fr-FR')"></td>
                        <td class="small" x-text="s.fin ? new Date(s.fin).toLocaleString('fr-FR') : '—'"></td>
                        <td class="small" x-text="s.dureeMinutes ? formatDuree(s.dureeMinutes * 60) : '—'"></td>
                        <td class="small" x-text="s.dossierTitre || s.clientNom || '—'"></td>
                        <td class="small" x-text="s.tauxHoraire + ' €/h'"></td>
                        <td class="small fw-semibold" style="color:var(--orange)" x-text="s.montantFacturable ? s.montantFacturable.toLocaleString('fr-FR', {style:'currency',currency:'EUR'}) : '—'"></td>
                        <td class="small" x-text="s.description || '—'"></td>
                        <td><i class="fa fa-trash text-muted" style="cursor:pointer;opacity:0.4" @click="deleteSession(s.id)"></i></td>
                    </tr>
                </template>
            </tbody>
        </table>
    </div>
</div>
</div>
{% endblock %}
{% block javascripts %}
<script>
const _tempsDossiers = {{ dossiers|map(d => {'id': d.id, 'titre': d.titre, 'clientId': d.client ? d.client.id : null})|json_encode|raw }};
</script>
<script>
function gestionTemps(tauxDefaut, sessionEnCoursId) {
    const allDossiers = _tempsDossiers;
    return {
        sessions: [], loading: true, sessionActive: sessionEnCoursId !== null,
        sessionEnCoursId: sessionEnCoursId, elapsed: 0, timer: null, startTime: null,
        allDossiers: allDossiers, filteredDossiers: allDossiers,
        newSession: { clientId:'', dossierId:'', tauxHoraire: tauxDefaut, description:'' },

        async init() {
            await this.loadSessions();
            if (this.sessionActive) {
                // Reprendre le chrono
                const s = this.sessions.find(s => s.id === sessionEnCoursId);
                if (s) {
                    this.startTime = new Date(s.debut).getTime();
                    this.elapsed = Math.floor((Date.now() - this.startTime) / 1000);
                    this.timer = setInterval(() => this.elapsed++, 1000);
                    // Pré-remplir les champs
                    if (s.dossierId) this.newSession.dossierId = String(s.dossierId);
                    if (s.clientId) this.newSession.clientId = String(s.clientId);
                    this.newSession.tauxHoraire = s.tauxHoraire;
                }
            }
        },

        onClientChange() {
            const clientId = this.newSession.clientId;
            if (!clientId) {
                this.filteredDossiers = this.allDossiers;
                this.newSession.dossierId = '';
                return;
            }
            const linked = this.allDossiers.filter(d => String(d.clientId) === String(clientId));
            this.filteredDossiers = linked.length > 0 ? linked : this.allDossiers;
            if (linked.length === 1) {
                this.newSession.dossierId = String(linked[0].id);
            } else if (!linked.find(d => String(d.id) === this.newSession.dossierId)) {
                this.newSession.dossierId = '';
            }
        },

        onDossierChange() {
            const dossier = this.allDossiers.find(d => String(d.id) === String(this.newSession.dossierId));
            if (!dossier) {
                this.newSession.clientId = '';
                this.filteredDossiers = this.allDossiers;
                return;
            }
            if (dossier.clientId) {
                this.newSession.clientId = String(dossier.clientId);
                this.filteredDossiers = this.allDossiers.filter(d => String(d.clientId) === String(dossier.clientId));
            }
        },

        async loadSessions() {
            this.loading = true;
            const data = await api.get('/api/sessions');
            if (data.success) this.sessions = data.data;
            this.loading = false;
        },

        async demarrer() {
            const data = await api.post('/api/sessions', {
                ...this.newSession,
                debut: new Date().toISOString()
            });
            if (data.success) {
                this.sessionEnCoursId = data.data.id;
                this.sessionActive = true;
                this.startTime = Date.now();
                this.elapsed = 0;
                this.timer = setInterval(() => this.elapsed++, 1000);
                this.sessions.unshift(data.data);
                notify('Session démarrée');
            } else notify(data.error, 'error');
        },

        async arreter() {
            clearInterval(this.timer);
            const data = await api.post(`/api/sessions/${this.sessionEnCoursId}/stop`);
            if (data.success) {
                this.sessionActive = false;
                this.sessionEnCoursId = null;
                this.elapsed = 0;
                notify('Session arrêtée : ' + this.formatDuree(data.data.dureeMinutes * 60));
                await this.loadSessions();
            }
        },

        async deleteSession(id) {
            if (!confirm('Supprimer cette session ?')) return;
            const data = await api.delete(`/api/sessions/${id}`);
            if (data.success) { this.sessions = this.sessions.filter(s => s.id !== id); notify('Supprimé'); }
        },

        formatDuree(seconds) {
            const h = Math.floor(seconds / 3600);
            const m = Math.floor((seconds % 3600) / 60);
            const s = seconds % 60;
            return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
        }
    };
}
</script>
{% endblock %}
