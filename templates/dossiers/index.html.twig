{% extends 'base.html.twig' %}

{% block title %}Dossiers - CRM Cabinet{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item active">Dossiers</li>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold"><!--i class="fa fa-folder-open text-warning me-2"></i-->Dossiers</h4>
    <a href="{{ path('dossier_new') }}" class="btn btn-outline-orange">
        <i class="fa fa-plus me-1"></i>Nouveau dossier
    </a>
</div>

<!-- Filtres -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Titre, client...">
            </div>
            <div class="col-md-2">
                <select id="statutFilter" class="form-select form-select-sm">
                    <option value="">Tous les statuts</option>
                    {% for statut in statuts %}
                    <option value="{{ statut.value }}">{{ statut.label() }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <select id="matiereFilter" class="form-select form-select-sm">
                    <option value="">Toutes les matières</option>
                    {% for matiere in matieres %}
                    <option value="{{ matiere.label }}">{{ matiere.label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-auto">
                <!--button class="btn btn-sm btn-outline-secondary" onclick="resetFilters()"><i class="fa fa-rotate-left"></i></button-->
                <button class="btn btn-sm btn-outline-secondary" onclick="resetFilters()"><i class="fa fa-rotate-left me-1"></i>Réinitialiser</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table text-nowrap align-middle table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>N° Dossier</th>
                    <th>Dossier</th>
                    <th>Client</th>
                    <th>Matière</th>
                    <th>Partie adverse</th>
                    <th>Statut</th>
                    <th>Ouvert le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="dossiersBody">
                <tr><td colspan="8" class="text-center py-4 text-muted fst-italic small"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</td></tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
let allDossiers = [];

async function loadDossiers() {
    const data = await api.get('/api/dossiers');
    if (!data.success) return;
    allDossiers = data.data;
    renderTable(allDossiers);
}
const matiereColors = {{ couleurs_matieres|json_encode|raw }};
const statutColors = {{ couleurs_statuts|json_encode|raw }};

function statutBadge(statut) {
    const color = statutColors[statut] || '#6c757d';
    return `<span class="badge" style="background:${color};color:#F8FAFC">${statut}</span>`;
}

function renderTable(dossiers) {
    const tbody = document.getElementById('dossiersBody');
    if (!dossiers.length) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-4 text-muted">Aucun dossier</td></tr>';
        return;
    }
    tbody.innerHTML = dossiers.map(d => {
        const color = matiereColors[d.matiere] || '#6B7280';
        const partieAdverse = d.partieAdverseEntreprise || [d.partieAdversePrenom, d.partieAdverseNom].filter(Boolean).join(' ') || '';
        return `
        <tr>
            <td><span class="badge bg-light text-dark border font-monospace small" style="font-size:0.7rem">${d.numeroDossier || '—'}</span></td>
            <td>
                <div class="d-flex align-items-center gap-2">
                    <!--div class="rounded flex-shrink-0" style="width:4px;height:36px;background:${d.couleur}"></div-->
                    <a href="/dossiers/${d.id}" class="text-decoration-none fw-semibold">${d.titre}</a>
                </div>
            </td>
            <td class="text-uppercase fw-normal"><a href="/clients/${d.clientId}" class="text-decoration-none small">${d.clientNom || '—'}</a></td>
            <td>${d.matiere ? `<span class="badge" style="background:${color}">${d.matiere}</span>` : '<span class="text-muted small">—</span>'}</td>
            <td class="small text-uppercase fw-normal">${partieAdverse}</td>
            <td>${statutBadge(d.statut)}</td>
            <td class="small">${new Date(d.dateOuverture).toLocaleDateString('fr-FR')}</td>
            <td>
                <!--div class="btn-group btn-group-sm">
                    <a href="/dossiers/${d.id}" class="btn btn-outline-primary"><i class="fa fa-eye"></i></a>
                    <a href="/dossiers/${d.id}/modifier" class="btn btn-outline-secondary"><i class="fa fa-pencil"></i></a>
                    <button class="btn btn-outline-danger" onclick="deleteDossier(${d.id}, '${d.titre.replace(/'/g, "\\'")}')"><i class="fa fa-trash"></i></button>
                </div-->

                 <div class="d-flex gap-2">
                    <!-- Icône Modifier (Gris, s'assombrit au survol) -->
                    <a href="/dossiers/${d.id}/modifier" 
                    class="btn btn-link btn-sm text-secondary p-1" 
                    title="Modifier">
                        <i class="fa fa-pencil"></i>
                    </a>

                    <!-- Icône Supprimer (Même comportement gris, ou rouge discret si tu préfères) -->
                    <button type="button" 
                            class="btn btn-link btn-sm text-secondary p-1" 
                            title="Supprimer" 
                            onclick="deleteDossier(${d.id}, '${d.titre.replace(/'/g, '\\\'')}')">
                        <i class="fa fa-trash fa-sm"></i>
                    </button>
                </div>

            </td>
        </tr>`;
    }).join('');
}

function applyFilters() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    const statut = document.getElementById('statutFilter').value;
    const matiere = document.getElementById('matiereFilter').value;
    let filtered = allDossiers;
    if (q) filtered = filtered.filter(d => (d.titre + (d.clientNom || '')).toLowerCase().includes(q));
    if (statut) filtered = filtered.filter(d => d.statut === statut);
    if (matiere) filtered = filtered.filter(d => d.matiere === matiere);
    renderTable(filtered);
}

function resetFilters() {
    ['searchInput','statutFilter','matiereFilter'].forEach(id => document.getElementById(id).value = '');
    renderTable(allDossiers);
}

async function deleteDossier(id, titre) {
    if (!confirm(`Supprimer le dossier "${titre}" ? Cette action est irréversible.`)) return;
    const data = await api.delete(`/api/dossiers/${id}`);
    if (data.success) { notify('Dossier supprimé'); loadDossiers(); }
    else notify(data.error || 'Erreur', 'error');
}

['searchInput','statutFilter','matiereFilter'].forEach(id => {
    document.getElementById(id).addEventListener('input', applyFilters);
    document.getElementById(id).addEventListener('change', applyFilters);
});

loadDossiers();
</script>
{% endblock %}
