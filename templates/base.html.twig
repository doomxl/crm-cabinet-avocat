<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}CRM Cabinet Avocat{% endblock %}</title>

    {{ include('partials/base/_favicons.html.twig') }}
    {{ include('partials/base/_stylesheets.html.twig') }}
    {# Styles personnalisés : sidebar, topbar, cards, KPI, recherche globale, urgences → assets/styles/app.css #}

    {% block stylesheets %}{% endblock %}
</head>
<body x-data="globalSearch()">

{{ include('partials/base/_sidebar.html.twig') }}

<!-- ==================== TOPBAR ==================== -->
<div id="topbar">
    <nav aria-label="breadcrumb" class="ms-2 flex-shrink-0">
        <ol class="breadcrumb mb-0">
            {% block breadcrumb %}
            <li class="breadcrumb-item active">Tableau de bord</li>
            {% endblock %}
        </ol>
    </nav>
    {{ include('partials/base/_topbar.html.twig') }}
</div>

{{ include('partials/base/_search.html.twig') }}

<!-- ==================== CONTENT ==================== -->
<div id="main-content">
    {% block content %}{% endblock %}
</div>

<!-- Toastr container -->
<div id="toast-container"></div>

{{ include('partials/base/_scripts.html.twig') }}

{% block javascripts %}{% endblock %}
{% block importmap %}{{ importmap('app') }}{% endblock %}

</body>
</html>
