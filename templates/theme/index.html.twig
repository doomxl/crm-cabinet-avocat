{% extends 'base.html.twig' %}
{% block title %}Thème - CRM Cabinet{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item active">Thème</li>
{% endblock %}
{% block content %}
<div x-data="themePage()" x-init="init()">

<h4 class="mb-3 fw-bold">Thème</h4>

<div class="row g-3">

    <!-- Colonne gauche : Matières + Actes générés -->
    <div class="col-lg-6 d-flex flex-column gap-3">

        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center py-2">
                <span class="small"><i class="fa fa-palette me-2 text-dark"></i>Couleurs des matières</span>
                <div class="d-flex gap-1">
                    <button class="btn btn-xs btn-outline-secondary" @click="reinitialiserMatieres()" data-bs-toggle="tooltip" title="Réinitialiser aux couleurs par défaut" x-init="new bootstrap.Tooltip($el)"><i class="fa fa-rotate-left"></i></button>
                    <button class="btn btn-xs btn-outline-orange" @click="sauvegarderMatieres()" :disabled="savingMatieres">
                        <i class="fa fa-floppy-disk flash-orange"></i>
                        <span x-text="savingMatieres ? '...' : 'Enregistrer'"></span>
                    </button>
                </div>
            </div>
            <div class="card-body py-2">
                <div class="row g-2">
                    <template x-for="m in matieres" :key="m.label">
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-1 p-1 rounded border bg-light">
                                <input type="color" class="form-control form-control-color flex-shrink-0"
                                       x-model="m.couleur" style="width:26px;height:26px;padding:1px;cursor:pointer;">
                                <span class="small" x-text="m.label"></span>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center py-2">
                <span class="small"><i class="fa fa-file-contract me-2 text-dark"></i>Statuts d'actes générés</span>
                <div class="d-flex gap-1">
                    <button class="btn btn-xs btn-outline-secondary" @click="reinitialiserStatutsActe()" data-bs-toggle="tooltip" title="Réinitialiser aux couleurs par défaut" x-init="new bootstrap.Tooltip($el)"><i class="fa fa-rotate-left"></i></button>
                    <button class="btn btn-xs btn-outline-orange" @click="sauvegarderStatutsActe()" :disabled="savingStatutsActe">
                        <i class="fa fa-floppy-disk flash-orange"></i> <span x-text="savingStatutsActe ? '...' : 'Enregistrer'"></span>
                    </button>
                </div>
            </div>
            <div class="card-body py-2">
                <div class="row g-2">
                    <template x-for="s in statutsActe" :key="s.label">
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-1 p-1 rounded border bg-light">
                                <input type="color" class="form-control form-control-color flex-shrink-0" x-model="s.couleur" style="width:26px;height:26px;padding:1px;cursor:pointer;">
                                <span class="badge" :style="'background:' + s.couleur" x-text="s.label" style="font-size:0.65rem;color:#F8FAFC"></span>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>

    </div>

    <!-- Colonne droite : 3 cards empilées -->
    <div class="col-lg-6 d-flex flex-column gap-3">

        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center py-2">
                <span class="small"><i class="fa fa-tag me-2 text-dark"></i>Statuts de dossier</span>
                <div class="d-flex gap-1">
                    <button class="btn btn-xs btn-outline-secondary" @click="reinitialiserStatuts()" data-bs-toggle="tooltip" title="Réinitialiser aux couleurs par défaut" x-init="new bootstrap.Tooltip($el)"><i class="fa fa-rotate-left"></i></button>
                    <button class="btn btn-xs btn-outline-orange" @click="sauvegarderStatuts()" :disabled="savingStatuts">
                        <i class="fa fa-floppy-disk flash-orange"></i> <span x-text="savingStatuts ? '...' : 'Enregistrer'"></span>
                    </button>
                </div>
            </div>
            <div class="card-body py-2">
                <div class="row g-2">
                    <template x-for="s in statuts" :key="s.label">
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-1 p-1 rounded border bg-light">
                                <input type="color" class="form-control form-control-color flex-shrink-0" x-model="s.couleur" style="width:26px;height:26px;padding:1px;cursor:pointer;">
                                <span class="badge" :style="'background:' + s.couleur" x-text="s.label" style="font-size:0.65rem;color:#F8FAFC"></span>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center py-2">
                <span class="small"><i class="fa fa-file-invoice-dollar me-2 text-dark"></i>Statuts d'honoraires</span>
                <div class="d-flex gap-1">
                    <button class="btn btn-xs btn-outline-secondary" @click="reinitialiserStatutsFacture()" data-bs-toggle="tooltip" title="Réinitialiser aux couleurs par défaut" x-init="new bootstrap.Tooltip($el)"><i class="fa fa-rotate-left"></i></button>
                    <button class="btn btn-xs btn-outline-orange" @click="sauvegarderStatutsFacture()" :disabled="savingStatutsFacture">
                        <i class="fa fa-floppy-disk flash-orange"></i> <span x-text="savingStatutsFacture ? '...' : 'Enregistrer'"></span>
                    </button>
                </div>
            </div>
            <div class="card-body py-2">
                <div class="row g-2">
                    <template x-for="s in statutsFacture" :key="s.label">
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-1 p-1 rounded border bg-light">
                                <input type="color" class="form-control form-control-color flex-shrink-0" x-model="s.couleur" style="width:26px;height:26px;padding:1px;cursor:pointer;">
                                <span class="badge" :style="'background:' + s.couleur" x-text="s.label" style="font-size:0.65rem;color:#F8FAFC"></span>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center py-2">
                <span class="small"><i class="fa fa-bolt-lightning me-2 text-dark"></i>Badges de conflits</span>
                <div class="d-flex gap-1">
                    <button class="btn btn-xs btn-outline-secondary" @click="reinitialiserConflits()" data-bs-toggle="tooltip" title="Réinitialiser aux couleurs par défaut" x-init="new bootstrap.Tooltip($el)"><i class="fa fa-rotate-left"></i></button>
                    <button class="btn btn-xs btn-outline-orange" @click="sauvegarderConflits()" :disabled="savingConflits">
                        <i class="fa fa-floppy-disk flash-orange"></i> <span x-text="savingConflits ? '...' : 'Enregistrer'"></span>
                    </button>
                </div>
            </div>
            <div class="card-body py-2">
                <div class="row g-2">
                    <template x-for="c in conflits" :key="c.label">
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-1 p-1 rounded border bg-light">
                                <input type="color" class="form-control form-control-color flex-shrink-0" x-model="c.couleur" style="width:26px;height:26px;padding:1px;cursor:pointer;">
                                <span class="badge" :style="'background:' + c.couleur" x-text="c.label" style="font-size:0.65rem;color:#F8FAFC"></span>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>

    </div>
</div>

</div>
{% endblock %}
{% block javascripts %}
<script>
function themePage() {
    return {
        matieres:       {{ matieres|json_encode|raw }},
        statuts:        {{ statuts|json_encode|raw }},
        statutsActe:    {{ statutsActe|json_encode|raw }},
        statutsFacture: {{ statutsFacture|json_encode|raw }},
        conflits:       {{ conflits|json_encode|raw }},
        savingMatieres: false,
        savingStatuts: false,
        savingStatutsActe: false,
        savingStatutsFacture: false,
        savingConflits: false,

        init() {},

        textColor(hex) {
            const r = parseInt(hex.slice(1,3),16);
            const g = parseInt(hex.slice(3,5),16);
            const b = parseInt(hex.slice(5,7),16);
            return (r*299 + g*587 + b*114) / 1000 > 128 ? '#374151' : '#ffffff';
        },

        reinitialiserMatieres() {
            this.matieres = this.matieres.map(m => ({ ...m, couleur: m.defaut }));
            notify('Couleurs réinitialisées — cliquez sur Enregistrer pour confirmer', 'info');
        },

        async sauvegarderMatieres() {
            this.savingMatieres = true;
            const couleursMatiere = {};
            this.matieres.forEach(m => { couleursMatiere[m.label] = m.couleur; });
            const data = await api.patch('/api/config', { couleursMatiere });
            if (data.success) notify('Couleurs des matières enregistrées', 'success');
            else notify(data.error || 'Erreur', 'error');
            this.savingMatieres = false;
        },

        reinitialiserStatuts() {
            this.statuts = this.statuts.map(s => ({ ...s, couleur: s.defaut }));
            notify('Couleurs réinitialisées — cliquez sur Enregistrer pour confirmer', 'info');
        },

        async sauvegarderStatuts() {
            this.savingStatuts = true;
            const couleursStatut = {};
            this.statuts.forEach(s => { couleursStatut[s.label] = s.couleur; });
            const data = await api.patch('/api/config', { couleursStatut });
            if (data.success) notify('Couleurs des statuts enregistrées', 'success');
            else notify(data.error || 'Erreur', 'error');
            this.savingStatuts = false;
        },

        reinitialiserStatutsActe() {
            this.statutsActe = this.statutsActe.map(s => ({ ...s, couleur: s.defaut }));
            notify('Couleurs réinitialisées — cliquez sur Enregistrer pour confirmer', 'info');
        },

        reinitialiserConflits() {
            this.conflits = this.conflits.map(c => ({ ...c, couleur: c.defaut }));
            notify('Couleurs réinitialisées — cliquez sur Enregistrer pour confirmer', 'info');
        },

        async sauvegarderConflits() {
            this.savingConflits = true;
            const couleursConflit = {};
            this.conflits.forEach(c => { couleursConflit[c.label] = c.couleur; });
            const data = await api.patch('/api/config', { couleursConflit });
            if (data.success) notify('Couleurs des conflits enregistrées', 'success');
            else notify(data.error || 'Erreur', 'error');
            this.savingConflits = false;
        },

        reinitialiserStatutsFacture() {
            this.statutsFacture = this.statutsFacture.map(s => ({ ...s, couleur: s.defaut }));
            notify('Couleurs réinitialisées — cliquez sur Enregistrer pour confirmer', 'info');
        },

        async sauvegarderStatutsFacture() {
            this.savingStatutsFacture = true;
            const couleursStatutFacture = {};
            this.statutsFacture.forEach(s => { couleursStatutFacture[s.label] = s.couleur; });
            const data = await api.patch('/api/config', { couleursStatutFacture });
            if (data.success) notify('Couleurs des statuts d\'honoraires enregistrées', 'success');
            else notify(data.error || 'Erreur', 'error');
            this.savingStatutsFacture = false;
        },

        async sauvegarderStatutsActe() {
            this.savingStatutsActe = true;
            const couleursStatutActe = {};
            this.statutsActe.forEach(s => { couleursStatutActe[s.label] = s.couleur; });
            const data = await api.patch('/api/config', { couleursStatutActe });
            if (data.success) notify('Couleurs des statuts d\'actes enregistrées', 'success');
            else notify(data.error || 'Erreur', 'error');
            this.savingStatutsActe = false;
        },
    };
}
</script>
{% endblock %}
