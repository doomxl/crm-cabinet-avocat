{% extends 'base.html.twig' %}
{% block title %}Honoraires - CRM Cabinet{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item active">Honoraires</li>
{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Honoraires &amp; Factures</h4>
    <a href="{{ path('facture_new') }}" class="btn btn-primary"><i class="fa fa-plus me-1"></i>Nouvelle facture</a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2">
            <div class="col-md-4">
                <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="N° facture, client...">
            </div>
            <div class="col-md-3">
                <select id="statutFilter" class="form-select form-select-sm">
                    <option value="">Tous les statuts</option>
                    {% for statut in statuts %}
                    <option value="{{ statut.value }}">{{ statut.label() }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <select id="typeFilter" class="form-select form-select-sm">
                    <option value="">Tous les types</option>
                    {% for type in typesDocument %}
                    <option value="{{ type.value }}">{{ type.label() }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>N°</th><th>Client</th><th>Type</th><th>Date</th><th>Montant TTC</th><th>Payé</th><th>Solde</th><th>Statut</th><th>Actions</th></tr>
            </thead>
            <tbody id="facturesBody">
                <tr><td colspan="9" class="text-center py-4 text-muted fst-italic small"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <span id="totalMontantWrapper" class="small text-muted" style="display:none">Total : <strong id="totalMontant" class="fw-semibold">—</strong></span>
        <span id="totalImpayeWrapper" class="small flash-orange" style="display:none">Impayé : <strong id="totalImpaye" class="fw-semibold">—</strong></span>
    </div>
</div>
{% endblock %}
{% block javascripts %}
<script>
let allFactures = [];

async function loadFactures() {
    const data = await api.get('/api/factures');
    if (!data.success) return;
    allFactures = data.data;
    renderTable(allFactures);
    updateTotals(allFactures);
}

const statutColors = {
    'En cours': 'badge-soft-blue', 'Payée': 'badge-soft-green', 'Partiellement payée': 'badge-soft-orange',
    'Annulée': 'badge-soft-gray', 'En retard': 'badge-soft-red'
};

function renderTable(factures) {
    const tbody = document.getElementById('facturesBody');
    if (!factures.length) { tbody.innerHTML = '<tr><td colspan="9" class="text-center py-4 text-muted">Aucune facture</td></tr>'; return; }
    tbody.innerHTML = factures.map(f => `
        <tr>
            <td><a href="/honoraires/${f.id}" class="text-decoration-none fw-semibold small">${f.numero}</a></td>
            <td class="small text-uppercase fw-semibold">${f.clientNom || '—'}</td>
            <td class="small">${f.typeDocument}</td>
            <td class="small">${new Date(f.dateEmission).toLocaleDateString('fr-FR')}</td>
            <td class="small fw-semibold">${f.montantTtc.toLocaleString('fr-FR', {style:'currency',currency:'EUR'})}</td>
            <td class="small fw-semibold text-dark">${f.montantPaye.toLocaleString('fr-FR', {style:'currency',currency:'EUR'})}</td>
            <td class="small fw-semibold" style="color:var(--orange)">${f.soldeRestant.toLocaleString('fr-FR', {style:'currency',currency:'EUR'})}</td>
            <td><span class="badge ${statutColors[f.statut] || 'bg-secondary'}">${f.statut}</span></td>
            <td>
                <div class="d-flex gap-1">
                    <a href="/honoraires/${f.id}" class="btn btn-sm btn-link text-secondary p-1" title="Voir"><i class="fa fa-eye"></i></a>
                    <a href="/api/factures/${f.id}/pdf" class="btn btn-sm btn-link text-secondary p-1" title="PDF"><i class="fa fa-file-pdf"></i></a>
                    <button class="btn btn-sm btn-link text-secondary p-1" title="Supprimer" onclick="deleteFacture(${f.id})"><i class="fa fa-trash"></i></button>
                </div>
            </td>
        </tr>`).join('');
}

function updateTotals(factures) {
    const total = factures.reduce((s, f) => s + f.montantTtc, 0);
    const impaye = factures.reduce((s, f) => s + f.soldeRestant, 0);
    const totalWrapper = document.getElementById('totalMontantWrapper');
    const impayeWrapper = document.getElementById('totalImpayeWrapper');
    if (total > 0) {
        document.getElementById('totalMontant').textContent = total.toLocaleString('fr-FR', {style:'currency',currency:'EUR'});
        totalWrapper.style.display = '';
    } else {
        totalWrapper.style.display = 'none';
    }
    if (impaye > 0) {
        document.getElementById('totalImpaye').textContent = impaye.toLocaleString('fr-FR', {style:'currency',currency:'EUR'});
        impayeWrapper.style.display = '';
    } else {
        impayeWrapper.style.display = 'none';
    }
}

function applyFilters() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    const statut = document.getElementById('statutFilter').value;
    const type = document.getElementById('typeFilter').value;
    let filtered = allFactures;
    if (q) filtered = filtered.filter(f => (f.numero + (f.clientNom || '')).toLowerCase().includes(q));
    if (statut) filtered = filtered.filter(f => f.statut === statut);
    if (type) filtered = filtered.filter(f => f.typeDocument === type);
    renderTable(filtered);
    updateTotals(filtered);
}

async function deleteFacture(id) {
    if (!confirm('Supprimer cette facture ?')) return;
    const data = await api.delete(`/api/factures/${id}`);
    if (data.success) { notify('Facture supprimée'); loadFactures(); }
    else notify(data.error || 'Erreur', 'error');
}

document.getElementById('searchInput').addEventListener('input', applyFilters);
document.getElementById('statutFilter').addEventListener('change', applyFilters);
document.getElementById('typeFilter').addEventListener('change', applyFilters);
loadFactures();
</script>
{% endblock %}
