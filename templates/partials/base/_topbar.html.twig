    <div class="flex-grow-1 d-flex justify-content-center px-3 search-bar-wrapper">
        <input type="text"
               x-model="query"
               @keyup.debounce.400ms="search()"
               @keydown.escape="close()"
               class="form-control form-control-sm"
               placeholder="Nom, prénom, téléphone, SIRET, n° dossier, code client, adversaire...">
    </div>

    <div class="flex-shrink-0 d-flex align-items-center gap-3">
        <span class="text-muted small" id="current-date"></span>
    </div>
