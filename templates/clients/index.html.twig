{% extends 'base.html.twig' %}

{% block title %}Clients - CRM Cabinet{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item active">Clients</li>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold"><!--i class="fa fa-users text-primary me-2"></i-->Clients</h4>
    <a href="{{ path('client_new') }}" class="btn btn-outline-orange">
        <i class="fa fa-plus me-1"></i>Nouveau client
    </a>
</div>

<!-- Filtres inline -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-1 text-nowrap my-1">              
                <span class="small text-muted mb-1">Recherche</span> 
            </div>
            <div class="col-md-4">
                <!--label class="small text-muted mb-1">Recherche</label-->
                <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Nom, email, code client...">
            </div>
            <div class="col-md-2">
                <!--label class="small text-muted mb-1">Type</label-->
                <select id="typeFilter" class="form-select form-select-sm">
                    <option value="">Tous les types</option>
                    {% for type in typesClient %}
                    <option value="{{ type.value }}">{{ type.label() }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-auto">
                <button class="btn btn-sm btn-outline-secondary" onclick="resetFilters()"><i class="fa fa-rotate-left me-1"></i>Réinitialiser</button>
            </div>
            <div class="col-md-auto ms-auto">
                <button class="btn btn-sm btn-outline-orange" onclick="exportClients()"><i class="fa fa-file-csv me-1"></i>Exporter CSV</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table id="clientsTable" class="table text-nowrap align-middle table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Nom / Raison sociale</th>
                    <th>Type</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Ville</th>
                    <!--th>Dossiers</th-->
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="clientsBody">
                <tr><td colspan="8" class="text-center py-4 text-muted fst-italic small"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</td></tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
let allClients = [];
let table;

async function loadClients() {
    const data = await api.get('/api/clients?limit=500');
    if (!data.success) return;
    allClients = data.data;
    renderTable(allClients);
}

function renderTable(clients) {
    const tbody = document.getElementById('clientsBody');
    if (!clients.length) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-4 text-muted">Aucun client trouvé</td></tr>';
        return;
    }
    tbody.innerHTML = clients.map(c => `
        <tr>
            <td><span class="badge bg-light text-dark border font-monospace small" style="font-size:0.7rem">${c.codeClient || '—'}</span></td>
            <td class="text-uppercase">
                <a href="/clients/${c.id}" class="text-decoration-none fw-semibold">${c.nomComplet}</a>
                ${c.intitule && c.intitule !== c.nomComplet ? `<div class="small text-muted">${c.intitule}</div>` : ''}
            </td>
            <td><span class="badge bg-light text-dark border">${c.typeClient}</span></td>
            <td class="text-lowercase">${c.email ? `<a href="mailto:${c.email}" class="text-decoration-none small">${c.email}</a>` : '<span class="text-muted">—</span>'}</td>
            <td>${c.telephone ? `<a href="tel:${c.telephone}" class="text-decoration-none small">${c.telephone}</a>` : '<span class="text-muted">—</span>'}</td>
            <!--td class="small">${c.telephone || '—'}</td-->
            <td class="small text-uppercase">${[c.codePostal, c.ville].filter(Boolean).join(' ') || '—'}</td>
            <!--td><span class="badge bg-primary rounded-pill">?</span></td-->
            <!--td style="padding-top: 2px;"-->
            <td>
                <!--div class="btn-group btn-group-sm">                   
                    <a href="/clients/${c.id}/modifier" class="btn btn-outline-secondary" title="Modifier"><i class="fa fa-pencil"></i></a>
                    <button class="btn btn-outline-danger" title="Supprimer" onclick="deleteClient(${c.id}, '${c.nomComplet.replace(/'/g, "\\'")}')"><i class="fa fa-trash"></i></button>
                </div-->


                <div class="d-flex gap-2">
                    <!-- Icône Modifier (Gris, s'assombrit au survol) -->
                    <a href="/clients/${c.id}/modifier" 
                    class="btn btn-link btn-sm text-secondary p-1" 
                    title="Modifier">
                        <i class="fa fa-pencil"></i>
                    </a>

                    <!-- Icône Supprimer (Même comportement gris, ou rouge discret si tu préfères) -->
                    <button type="button" 
                            class="btn btn-link btn-sm text-secondary p-1" 
                            title="Supprimer" 
                            onclick="deleteClient(${c.id}, '${c.nomComplet.replace(/'/g, '\\\'')}')">
                        <i class="fa fa-trash fa-sm"></i>
                    </button>
                </div>



            </td>
        </tr>
    `).join('');
}

function applyFilters() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    const type = document.getElementById('typeFilter').value;
    let filtered = allClients;
    if (q) filtered = filtered.filter(c => (c.nomComplet + c.email + c.codeClient + c.intitule).toLowerCase().includes(q));
    if (type) filtered = filtered.filter(c => c.typeClient === type);
    renderTable(filtered);
}

function resetFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('typeFilter').value = '';
    renderTable(allClients);
}

async function deleteClient(id, nom) {
    if (!confirm(`Supprimer le client "${nom}" ?`)) return;
    const data = await api.delete(`/api/clients/${id}`);
    if (data.success) {
        notify('Client supprimé');
        loadClients();
    } else {
        notify(data.error || 'Erreur lors de la suppression', 'error');
    }
}

function exportClients() {
    window.location.href = '/api/clients/export-csv';
}

document.getElementById('searchInput').addEventListener('input', applyFilters);
document.getElementById('typeFilter').addEventListener('change', applyFilters);

loadClients();
</script>
{% endblock %}
