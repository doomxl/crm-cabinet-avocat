{% extends 'base.html.twig' %}

{% block title %}{{ client.nomComplet }} - CRM Cabinet{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item"><a href="{{ path('client_index') }}">Clients</a></li>
<li class="breadcrumb-item active">{{ client.nomComplet }}</li>
{% endblock %}

{% block content %}
<div x-data="clientDetail({{ client.id }})" x-init="init()">

<!-- Header -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="fw-bold mb-1"><!--i class="fa fa-user text-primary me-2"></i-->{{ client.nomComplet }}</h4>        
        <span class="badge bg-secondary me-2">{{ client.typeClient.value }}</span>
        
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-warning btn-sm" @click="verifierConflits()">
            <i class="fa-solid fa-bolt-lightning me-1"></i>Vérifier conflits
        </button>
        <a href="{{ path('client_edit', {id: client.id}) }}" class="btn btn-outline-primary btn-sm">
            <i class="fa fa-pencil me-1"></i>Modifier
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Fiche client -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><i class="fa fa-id-card me-2 flash-color"></i>Informations</div>
            <div class="card-body">
                <dl class="row small mb-0">
                    <dt class="col-12 fw-medium">Code client</dt>
                    <dd class="col-12">{{ client.codeClient }}</dd>
                    {% if client.email %}
                    <dt class="col-12 fw-medium">Email</dt>
                    <dd class="col-12"><a href="mailto:{{ client.email }}">{{ client.email }}</a></dd>
                    {% endif %}
                    {% if client.telephone %}
                    <dt class="col-12 fw-medium">Téléphone</dt>
                    <dd class="col-12"><a href="tel:{{ client.telephone }}">{{ client.telephone }}</a></dd>
                    {% endif %}
                    {% if client.adresse %}
                    <dt class="col-12 fw-medium">Adresse</dt>
                    <dd class="col-12">{{ client.adresse }}<br>{{ client.codePostal }} {{ client.ville }}</dd>
                    {% endif %}
                    {% if client.siret %}
                    <dt class="col-12 fw-medium">SIRET</dt>
                    <dd class="col-12">{{ client.siret }}</dd>
                    {% endif %}
                    {% if client.typeSociete %}
                    <dt class="col-12 fw-medium">Forme juridique</dt>
                    <dd class="col-12">{{ client.typeSociete }}</dd>
                    {% endif %}
                    <dt class="col-12 fw-medium">Créé le</dt>
                    <dd class="col-12">{{ client.createdAt|date('d/m/Y') }}</dd>
                </dl>
            </div>
        </div>

        <!-- Alerte conflits -->
        <div class="card mb-3" style="display: none;" x-show="conflits.length > 0">
            <div class="card-header text-danger"><i class="fa fa-triangle-exclamation me-2"></i>Conflits détectés</div>
            <div class="card-body p-0">
                <template x-for="c in conflits" :key="c.message">
                    <div class="px-3 py-2 border-bottom small">
                        <div class="fw-semibold text-danger" x-text="c.message"></div>
                        <div class="text-muted" x-text="'Dossier : ' + (c.dossier?.titre ?? '—')"></div>
                    </div>
                </template>
            </div>
        </div>
    </div>

    <!-- Dossiers, Factures, RDV -->
    <div class="col-lg-8">

        <!-- Dossiers -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-folder me-2  flash-color"></i>Dossiers (<span x-text="dossiers.length"></span>)</span>
                <a href="{{ path('dossier_new') }}?clientId={{ client.id }}" class="btn btn-sm btn-outline-primary">
                    <i class="fa fa-plus me-1"></i>Nouveau dossier
                </a>
            </div>
            <div class="card-body p-0">
                <template x-if="dossiers.length === 0">
                    <div class="text-center text-muted py-3 small">Aucun dossier</div>
                </template>
                <template x-for="d in dossiers" :key="d.id">
                    <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom">
                        <div class="rounded-circle flex-shrink-0" :style="`width:10px;height:10px;background:${d.couleur}`"></div>
                        <div class="flex-grow-1">
                            <a :href="`/dossiers/${d.id}`" class="text-decoration-none fw-semibold small" x-text="d.titre"></a>
                            
                        </div>
                        <span class="badge bg-secondary" x-text="d.matiere ?? 'Matière non définie'"></span>
                        <span class="badge" :class="d.statut === 'En cours' ? 'bg-primary' : 'bg-secondary'" x-text="d.statut"></span>
                        <div class="small text-muted" x-text="new Date(d.dateOuverture).toLocaleDateString('fr-FR')"></div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Factures -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-file-invoice-dollar me-2  flash-color"></i>Honoraires (<span x-text="factures.length"></span>)</span>
                <a href="{{ path('facture_new') }}?clientId={{ client.id }}" class="btn btn-sm btn-outline-success">
                    <i class="fa fa-plus me-1"></i>Nouvelle facture
                </a>
            </div>
            <div class="card-body p-0">
                <template x-if="factures.length === 0">
                    <div class="text-center text-muted py-3 small">Aucune facture</div>
                </template>
                <template x-for="f in factures" :key="f.id">
                    <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom">
                        <div class="flex-grow-1">
                            <a :href="`/honoraires/${f.id}`" class="text-decoration-none fw-semibold small" x-text="f.numero"></a>
                            <div class="small text-muted" x-text="new Date(f.dateEmission).toLocaleDateString('fr-FR')"></div>
                        </div>
                        <div class="text-end">
                            <div class="small fw-bold" x-text="f.montantTtc.toLocaleString('fr-FR', {style:'currency',currency:'EUR'})"></div>
                            <div class="small text-danger" x-show="f.soldeRestant > 0" x-text="'Restant : ' + f.soldeRestant.toLocaleString('fr-FR', {style:'currency',currency:'EUR'})"></div>
                        </div>
                        <span class="badge"
                            :class="f.statut === 'Payée' ? 'bg-success' : f.statut === 'En retard' ? 'bg-danger' : f.statut === 'Partiellement payée' ? 'bg-warning text-dark' : 'bg-info text-dark'"
                            x-text="f.statut"></span>
                    </div>
                </template>
            </div>
        </div>

    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function clientDetail(clientId) {
    return {
        dossiers: [],
        factures: [],
        conflits: [],

        async init() {
            const [d, f] = await Promise.all([
                api.get(`/api/clients/${clientId}/dossiers`),
                api.get(`/api/clients/${clientId}/factures`),
            ]);
            if (d.success) this.dossiers = d.data;
            if (f.success) this.factures = f.data;
        },

        async verifierConflits() {
            const data = await api.post(`/api/clients/${clientId}/verifier-conflit`);
            if (data.success) {
                this.conflits = data.data.conflits;
                if (this.conflits.length === 0) {
                    notify('Aucun conflit détecté', 'success');
                } else {
                    notify(`${this.conflits.length} conflit(s) détecté(s)`, 'warning');
                }
            }
        }
    };
}
</script>
{% endblock %}
