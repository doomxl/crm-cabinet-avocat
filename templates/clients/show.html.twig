{% extends 'base.html.twig' %}

{% block title %}{{ client.nomComplet }} - CRM Cabinet{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item"><a href="{{ path('client_index') }}">Clients</a></li>
<li class="breadcrumb-item active">{{ client.nomComplet }}</li>
{% endblock %}

{% block content %}
<div x-data="clientDetail({{ client.id }})" x-init="init()">

<!-- Header -->
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h4 class="fw-bold mb-1"><!--i class="fa fa-user text-primary me-2"></i-->{{ client.nomComplet }}</h4>        
        <span class="badge bg-secondary me-2">{{ client.typeClient.value }}</span>
        
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-orange btn-sm" @click="verifierConflits()">
            <i class="fa-solid fa-bolt-lightning me-1"></i>Vérifier conflits
        </button>
        <a href="{{ path('client_edit', {id: client.id}) }}" class="btn btn-outline-orange btn-sm">
            <i class="fa fa-pencil me-1"></i>Modifier
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Fiche client -->
    <div class="col-lg-4">
        <div class="card mb-3 overflow-hidden">
            <div class="card-header"><i class="fa fa-id-card me-2 flash-color"></i>Informations</div>
            <div class="card-body p-0">
                <table class="table table-sm table-borderless small mb-0">
                    <tbody>
                        <tr>
                            <td class="fw-semibold ps-3" style="color:#374151" style="width:40%">Code client</td>
                            <td class="pe-3"><span class="badge bg-light text-dark border font-monospace" style="font-size:0.7rem">{{ client.codeClient ?? '—' }}</span></td>
                        </tr>
                        {% if client.email %}
                        <tr>
                            <td class="fw-semibold ps-3" style="color:#374151">Email</td>
                            <td class="pe-3"><a href="mailto:{{ client.email }}">{{ client.email }}</a></td>
                        </tr>
                        {% endif %}
                        {% if client.telephone %}
                        <tr>
                            <td class="fw-semibold ps-3" style="color:#374151">Téléphone</td>
                            <td class="pe-3"><a href="tel:{{ client.telephone }}">{{ client.telephone }}</a></td>
                        </tr>
                        {% endif %}
                        {% if client.adresse %}
                        <tr>
                            <td class="fw-semibold ps-3" style="color:#374151">Adresse</td>
                            <td class="pe-3">{{ client.adresse }}<br>{{ client.codePostal }} {{ client.ville }}</td>
                        </tr>
                        {% endif %}
                        {% if client.siret %}
                        <tr>
                            <td class="fw-semibold ps-3" style="color:#374151">SIRET</td>
                            <td class="pe-3">{{ client.siret }}</td>
                        </tr>
                        {% endif %}
                        {% if client.typeSociete %}
                        <tr>
                            <td class="fw-semibold ps-3" style="color:#374151">Forme juridique</td>
                            <td class="pe-3">{{ client.typeSociete }}</td>
                        </tr>
                        {% endif %}
                        <tr>
                            <td class="fw-semibold ps-3" style="color:#374151">Créé le</td>
                            <td class="pe-3">{{ client.createdAt|date('d/m/Y') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Alerte conflits -->
        <div class="card mb-3" style="display: none;" x-show="conflits.length > 0">
            <div class="card-header text-danger"><i class="fa fa-triangle-exclamation me-2"></i>Conflits détectés</div>
            <div class="card-body p-0">
                <template x-for="c in conflits" :key="c.message">
                    <div class="px-3 py-2 border-bottom small">
                        <div class="fw-semibold text-danger" x-text="c.message"></div>
                        <div class="text-muted" x-text="'Dossier : ' + (c.dossier?.titre ?? '—')"></div>
                    </div>
                </template>
            </div>
        </div>
    </div>

    <!-- Dossiers, Factures, RDV -->
    <div class="col-lg-8">

        <!-- Dossiers -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-folder me-2  flash-color"></i>Dossiers (<span x-text="dossiers.length"></span>)</span>
                <a href="{{ path('dossier_new') }}?clientId={{ client.id }}" class="btn btn-sm btn-outline-orange">
                    <i class="fa fa-plus me-1"></i>Nouveau dossier
                </a>
            </div>
            <div class="card-body p-0">
                <template x-if="loading">
                    <div class="text-center text-muted py-3 small fst-italic"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</div>
                </template>
                <template x-if="!loading && dossiers.length === 0">
                    <div class="text-center text-muted py-3 small">Aucun dossier</div>
                </template>
                <template x-for="d in dossiers" :key="d.id">
                    <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom">
                        <div class="flex-grow-1">
                            <a :href="`/dossiers/${d.id}`" class="text-decoration-none fw-semibold small" x-text="d.titre" :title="d.numeroDossier || ''" data-bs-toggle="tooltip"></a>
                            
                        </div>
                        <span class="badge" :style="'background:' + (matiereColors[d.matiere] || '#9CA3AF') + ';color:#F8FAFC'" x-text="d.matiere ?? 'Matière non définie'"></span>
                        <span class="badge" :style="'background:' + (statutColors[d.statut] || '#9CA3AF') + ';color:#F8FAFC'" x-text="d.statut"></span>
                        <div class="small text-muted" x-text="new Date(d.dateOuverture).toLocaleDateString('fr-FR')"></div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Factures -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-file-invoice-dollar me-2  flash-color"></i>Honoraires (<span x-text="factures.length"></span>)</span>
                <a href="{{ path('facture_new') }}?clientId={{ client.id }}" class="btn btn-sm btn-outline-orange">
                    <i class="fa fa-plus me-1"></i>Nouvelle facture
                </a>
            </div>
            <div class="card-body p-0">
                <template x-if="loading">
                    <div class="text-center text-muted py-3 small fst-italic"><i class="fa fa-spinner fa-spin me-2"></i>Chargement en cours...</div>
                </template>
                <template x-if="!loading && factures.length === 0">
                    <div class="text-center text-muted py-3 small">Aucune facture</div>
                </template>
                <template x-for="f in factures" :key="f.id">
                    <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom">
                        <div class="flex-grow-1">
                            <a :href="`/honoraires/${f.id}`" class="text-decoration-none fw-semibold small" x-text="f.numero"></a>
                            <div class="small text-muted" x-text="new Date(f.dateEmission).toLocaleDateString('fr-FR')"></div>
                        </div>
                        <span class="badge"
                            :style="'background:' + (statutFactureColors[f.statut] || '#9CA3AF') + ';color:#F8FAFC'"
                            x-text="f.statut"></span>
                        <div class="text-end">
                            <div class="small fw-bold" x-text="f.montantTtc.toLocaleString('fr-FR', {style:'currency',currency:'EUR'})"></div>
                            <div class="small" style="color:var(--orange)" x-show="f.soldeRestant > 0" x-text="'Restant : ' + f.soldeRestant.toLocaleString('fr-FR', {style:'currency',currency:'EUR'})"></div>
                        </div>
                    </div>
                </template>
            </div>
        </div>

    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
const _matiereColors       = {{ couleurs_matieres|json_encode|raw }};
const _statutColors        = {{ couleurs_statuts|json_encode|raw }};
const _statutFactureColors = {{ couleurs_statuts_facture|json_encode|raw }};
</script>
<script>
function clientDetail(clientId) {
    return {
        dossiers: [],
        factures: [],
        conflits: [],
        loading: true,
        matiereColors:       _matiereColors,
        statutColors:        _statutColors,
        statutFactureColors: _statutFactureColors,

        async init() {
            this.loading = true;
            const [d, f] = await Promise.all([
                api.get(`/api/clients/${clientId}/dossiers`),
                api.get(`/api/clients/${clientId}/factures`),
            ]);
            if (d.success) this.dossiers = d.data;
            if (f.success) this.factures = f.data;
            this.loading = false;
            this.$nextTick(() => {
                document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
            });
        },

        async verifierConflits() {
            const data = await api.post(`/api/clients/${clientId}/verifier-conflit`);
            if (data.success) {
                this.conflits = data.data.conflits;
                if (this.conflits.length === 0) {
                    notify('Aucun conflit détecté', 'success');
                } else {
                    notify(`${this.conflits.length} conflit(s) détecté(s)`, 'warning');
                }
            }
        }
    };
}
</script>
{% endblock %}
