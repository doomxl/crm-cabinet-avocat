{% extends 'base.html.twig' %}
{% block title %}Comptabilité BNC - CRM Cabinet{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('dashboard_index') }}">Accueil</a></li>
<li class="breadcrumb-item active">Comptabilité</li>
{% endblock %}
{% block content %}
<div x-data="comptabilite({{ anneeEnCours }})" x-init="init()">
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold"><i class="fa fa-calculator text-primary me-2"></i>Livre Journal BNC</h4>
    <div class="d-flex gap-2">
        <select class="form-select form-select-sm" style="width:auto" x-model="annee" @change="loadData()">
            <template x-for="y in annees" :key="y">
                <option :value="y" x-text="y"></option>
            </template>
        </select>
        <a :href="`/api/ecritures/export-csv?annee=${annee}`" class="btn btn-sm btn-outline-success"><i class="fa fa-file-csv me-1"></i>Export Journal</a>
        <a :href="`/api/ecritures/export-2035?annee=${annee}`" class="btn btn-sm btn-outline-primary"><i class="fa fa-file-excel me-1"></i>Export 2035</a>
        <button class="btn btn-sm btn-primary" @click="showAddEcriture = !showAddEcriture"><i class="fa fa-plus me-1"></i>Nouvelle écriture</button>
    </div>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="kpi-card" style="background:linear-gradient(135deg,#059669,#10b981)">
            <div class="kpi-value" x-text="totalRecettes.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0})"></div>
            <div class="kpi-label">Total Recettes</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card" style="background:linear-gradient(135deg,#dc2626,#ef4444)">
            <div class="kpi-value" x-text="totalDepenses.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0})"></div>
            <div class="kpi-label">Total Dépenses</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card" style="background:linear-gradient(135deg,#1e40af,#3b82f6)">
            <div class="kpi-value" x-text="(totalRecettes - totalDepenses).toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0})"></div>
            <div class="kpi-label">Bénéfice net</div>
        </div>
    </div>
</div>

<!-- Formulaire ajout écriture inline -->
<div class="card mb-3" x-show="showAddEcriture">
    <div class="card-header">Nouvelle écriture comptable</div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-2"><input type="date" class="form-control form-control-sm" x-model="newEcriture.date"></div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" x-model="newEcriture.type">
                    {% for type in typesEcriture %}
                    <option value="{{ type.value }}">{{ type.label() }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" x-model="newEcriture.categorie">
                    {% for cat in categories %}
                    <option value="{{ cat.value }}">{{ cat.value }} - {{ cat.label()|slice(0,25) }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3"><input class="form-control form-control-sm" x-model="newEcriture.libelle" placeholder="Libellé"></div>
            <div class="col-md-1"><input type="number" class="form-control form-control-sm" x-model="newEcriture.montant" placeholder="Montant" step="0.01"></div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" x-model="newEcriture.modeReglement">
                    <option value="">Mode de règlement</option>
                    {% for mode in modesReglement %}
                    <option value="{{ mode.value }}">{{ mode.value }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="mt-2 text-end">
            <button class="btn btn-sm btn-primary" @click="addEcriture()">Enregistrer</button>
            <button class="btn btn-sm btn-outline-secondary ms-1" @click="showAddEcriture = false">Annuler</button>
        </div>
    </div>
</div>

<!-- Bouton rapprochement -->
<div class="mb-3">
    <button class="btn btn-sm btn-outline-info" @click="rapprochement()">
        <i class="fa fa-link me-1"></i>Rapprochement automatique depuis les factures
    </button>
</div>

<!-- Tableau -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Journal des écritures <span class="badge bg-secondary" x-text="ecritures.length"></span></span>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width:auto" x-model="filtreType" @change="applyFilters()">
                <option value="">Tous</option>
                <option value="recette">Recettes</option>
                <option value="depense">Dépenses</option>
            </select>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr><th>Date</th><th>Type</th><th>Cat.</th><th>Libellé</th><th>Montant</th><th>Mode</th><th>Réf.</th><th></th></tr>
            </thead>
            <tbody>
                <template x-if="ecrituresFiltrees.length === 0">
                    <tr><td colspan="8" class="text-center py-4 text-muted">Aucune écriture</td></tr>
                </template>
                <template x-for="e in ecrituresFiltrees" :key="e.id">
                    <tr>
                        <td class="small" x-text="new Date(e.date).toLocaleDateString('fr-FR')"></td>
                        <td><span class="badge" :class="e.type === 'recette' ? 'bg-success' : 'bg-danger'" x-text="e.typeLabel"></span></td>
                        <td><code class="small" x-text="e.categorie"></code></td>
                        <td class="small" x-text="e.libelle"></td>
                        <td class="small fw-bold" :class="e.type === 'recette' ? 'text-success' : 'text-danger'" x-text="parseFloat(e.montant).toLocaleString('fr-FR',{style:'currency',currency:'EUR'})"></td>
                        <td class="small" x-text="e.modeReglement || '—'"></td>
                        <td class="small" x-text="e.reference || '—'"></td>
                        <td><button class="btn btn-xs btn-outline-danger" @click="deleteEcriture(e.id)"><i class="fa fa-times"></i></button></td>
                    </tr>
                </template>
            </tbody>
        </table>
    </div>
</div>

</div>
{% endblock %}
{% block javascripts %}
<script>
function comptabilite(anneeEnCours) {
    return {
        annee: anneeEnCours,
        annees: Array.from({length:5}, (_,i) => anneeEnCours - i),
        ecritures: [], ecrituresFiltrees: [],
        totalRecettes: 0, totalDepenses: 0,
        showAddEcriture: false, filtreType: '',
        newEcriture: { date: new Date().toISOString().split('T')[0], type:'recette', categorie:'AA', libelle:'', montant:0, modeReglement:'' },

        async init() { await this.loadData(); },

        async loadData() {
            const data = await api.get(`/api/ecritures?annee=${this.annee}`);
            if (data.success) {
                this.ecritures = data.data;
                this.applyFilters();
                this.calculerTotaux();
            }
        },

        applyFilters() {
            this.ecrituresFiltrees = this.filtreType ? this.ecritures.filter(e => e.type === this.filtreType) : this.ecritures;
        },

        calculerTotaux() {
            this.totalRecettes = this.ecritures.filter(e => e.type === 'recette').reduce((s,e) => s + parseFloat(e.montant), 0);
            this.totalDepenses = this.ecritures.filter(e => e.type === 'depense').reduce((s,e) => s + parseFloat(e.montant), 0);
        },

        async addEcriture() {
            const data = await api.post('/api/ecritures', this.newEcriture);
            if (data.success) {
                this.ecritures.unshift(data.data);
                this.applyFilters();
                this.calculerTotaux();
                this.showAddEcriture = false;
                notify('Écriture enregistrée');
            } else notify(data.error, 'error');
        },

        async deleteEcriture(id) {
            if (!confirm('Supprimer cette écriture ?')) return;
            const data = await api.delete(`/api/ecritures/${id}`);
            if (data.success) {
                this.ecritures = this.ecritures.filter(e => e.id !== id);
                this.applyFilters();
                this.calculerTotaux();
                notify('Supprimé');
            }
        },

        async rapprochement() {
            const data = await api.post('/api/ecritures/rapprochement');
            if (data.success) {
                notify(`${data.data.created} écriture(s) créée(s)`);
                await this.loadData();
            }
        }
    };
}
</script>
{% endblock %}
