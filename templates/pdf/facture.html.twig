<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
    @page { margin: 16mm; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
        font-family: Arial, sans-serif;
        font-size: 11px;
        color: #1a1a1a;
        line-height: 1.5;
        margin: 16mm;
    }

    /* En-tête cabinet */
    .header {
        display: table;
        width: 100%;
        margin-bottom: 10px;
        border-bottom: 3px solid #1a2942;
        padding-bottom: 12px;
    }
    .header-left { display: table-cell; width: 55%; vertical-align: top; }
    .header-right { display: table-cell; width: 45%; vertical-align: top; text-align: right; }

    .cabinet-nom { font-size: 20px; font-weight: bold; color: #1a2942; margin-bottom: 4px; }
    .cabinet-info { font-size: 9px; color: #555; line-height: 1.6; }

    /* Titre document */
    .document-titre { font-size: 18px; font-weight: bold; color: #1a2942; text-align: right; margin-bottom: 4px; }
    .document-numero { font-size: 12px; color: #666; text-align: right; }
    .document-date { font-size: 11px; color: #666; text-align: right; }
    .statut-wrap { margin-top: 6px; }

    /* Blocs client / infos */
    .blocs { display: table; width: 100%; margin-bottom: 20px; }
    .bloc-client { display: table-cell; width: 48%; vertical-align: top; }
    .bloc-spacer { display: table-cell; width: 4%; }
    .bloc-infos  { display: table-cell; width: 48%; vertical-align: top; }

    .bloc-titre {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #888;
        padding-bottom: 3px;
        margin-bottom: 0px;
        font-weight: bold;
    }
    .bloc-content {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 4px;
        padding: 8px 10px;
        font-size: 10px;
        line-height: 1.4;
    }

    .client-nom     { font-size: 12px; font-weight: bold; margin-bottom: 3px; text-transform: uppercase; }
    .client-adresse { text-transform: uppercase; line-height: 1.3; }
    .client-contact { line-height: 1.3; font-size: 9px; color: #444; margin-top: 4px; }

    .infos-table          { width: 100%; font-size: 10px; border-collapse: collapse; line-height: 1.35; }
    .infos-table .td-label { color: #666; width: 45%; }
    .infos-table .td-value { font-weight: 600; }

    /* Statut */
    .statut-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 3px;
        font-size: 9px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .statut-encours { background: #1a2942; color: #ffffff; }
    .statut-payee   { background: #1a2942; color: #ffffff; }
    .statut-partiel { background: #1a2942; color: #ffffff; }
    .statut-retard  { background: #1a2942; color: #ffffff; }
    .statut-annulee { background: #1a2942; color: #ffffff; }

    /* Tableau lignes */
    .tableau-lignes { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .tableau-lignes thead tr { background: #1a2942; color: white; }
    .tableau-lignes thead th {
        padding: 8px 10px;
        text-align: left;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }
    .tableau-lignes thead th.col-desc   { width: 55%; }
    .tableau-lignes thead th.col-qty    { width: 10%; text-align: right; }
    .tableau-lignes thead th.col-unite  { width: 10%; text-align: right; }
    .tableau-lignes thead th.col-pu     { width: 12%; text-align: right; }
    .tableau-lignes thead th.col-total  { width: 13%; text-align: right; }
    .tableau-lignes thead th.text-right { text-align: right; }

    .tableau-lignes tbody tr  { border-bottom: 1px solid #e9ecef; }
    .tableau-lignes tbody tr:nth-child(even) { background: #f8f9fa; }
    .tableau-lignes tbody td  { padding: 8px 10px; font-size: 9px; vertical-align: top; }
    .tableau-lignes tbody td.col-desc { text-transform: uppercase; }
    .tableau-lignes tbody td.text-right { text-align: right; }

    .tableau-lignes tfoot tr { border-top: 2px solid #1a2942; }
    .tableau-lignes tfoot td { padding: 5px 10px; font-size: 10px; }
    .tableau-lignes tfoot td.text-right { text-align: right; }
    .total-ttc td {
        font-size: 12px !important;
        font-weight: bold !important;
        color: #1a2942;
        border-top: 2px solid #1a2942;
        padding-top: 8px !important;
    }

    /* Totaux */
    .totaux       { display: table; width: 100%; margin-bottom: 20px; }
    .totaux-left  { display: table-cell; width: 70%; vertical-align: top; }
    .totaux-right { display: table-cell; width: 30%; vertical-align: top; text-align: right; }

    .totaux-table             { width: 100%; border-collapse: collapse; }
    .totaux-table td          { padding: 2px 2px; font-size: 10px; line-height: 1.3; }
    .totaux-table td.td-label { color: #666; width: 55%; }
    .totaux-table td.td-value { text-align: right; font-weight: 600; width: 20%; }
    .totaux-table td.td-green { color: #198754; text-align: right; font-weight: 600; width: 20%; }
    .totaux-table .ligne-ttc td {
        font-size: 12px;
        font-weight: bold;
        color: #1a2942;
        border-top: 1px solid #1a2942;
        padding-top: 5px;
        margin-top: 3px;
    }
    .totaux-table .ligne-ttc td.td-value { text-align: right; }
    .totaux-table .ligne-solde td {
        font-size: 12px;
        font-weight: bold;
        color: #1a2942;
        border-top: 1px solid #1a2942;
        padding-top: 5px;
    }
    .totaux-table .ligne-solde td.td-value { text-align: right; }

    /* Avocat */
    .reglement-bloc {
        background: #f0f7ff;
        border: 1px solid #b6d4fe;
        border-radius: 4px;
        padding: 10px 14px;
        margin-bottom: 15px;
        font-size: 9px;
    }
    .reglement-titre { font-weight: bold; margin-bottom: 4px; color: #1a2942; }

    /* Pied de page */
    .footer {
        position: fixed;
        bottom: 0; left: 0; right: 0;
        border-top: 1px solid #ddd;
        padding: 6px 0;
        font-size: 8px;
        color: #999;
        text-align: center;
    }
    .footer-table                        { width: 100%; }
    .footer-table td                     { padding: 0 15px; }
    .footer-table td:nth-child(2)        { text-align: center; }
    .footer-table td:nth-child(3)        { text-align: right; }

    .page-break { page-break-after: always; }
</style>
</head>
<body>

<!-- En-tête -->
<div class="header">
    <div class="header-left">
        <div class="cabinet-nom">{{ config.nom }}</div>
        <div class="cabinet-info">
            {% if config.adresse %}{{ config.adresse }}<br>{% endif %}
            {% if config.ville %}{{ config.codePostal }} {{ config.ville }}<br>{% endif %}
            {% if config.telephone %}Tél. : {{ config.telephone }}<br>{% endif %}
            {% if config.email %}{{ config.email }}<br>{% endif %}
            {% if config.siret %}SIRET : {{ config.siret }}{% endif %}
        </div>
    </div>
    <div class="header-right">
        <div class="document-titre">{{ facture.typeDocument.label() }}</div>
        <div class="document-numero">N° {{ facture.numero }}</div>
        <div class="document-date">Émise le {{ facture.dateEmission|date('d/m/Y') }}</div>
        <div class="statut-wrap">
            {% set statutClass = 'statut-encours' %}
            {% if facture.statut.value == 'Payée' %}
                {% set statutClass = 'statut-payee' %}
            {% elseif facture.statut.value == 'Partiellement payée' %}
                {% set statutClass = 'statut-partiel' %}
            {% elseif facture.statut.value == 'En retard' %}
                {% set statutClass = 'statut-retard' %}
            {% elseif facture.statut.value == 'Annulée' %}
                {% set statutClass = 'statut-annulee' %}
            {% endif %}
            <span class="statut-badge {{ statutClass }}">{{ facture.statut.label() }}</span>
        </div>
    </div>
</div>

<!-- Blocs client / infos -->
<div class="blocs">
    <div class="bloc-client">
        <div class="bloc-titre">Destinataire</div>
        <div class="bloc-content">
            <div class="client-nom">{{ facture.client.nomComplet }}</div>
            <div class="client-adresse">
                {% if facture.client.adresse %}{{ facture.client.adresse }}<br>{% endif %}
                {% if facture.client.ville %}{{ facture.client.codePostal }} {{ facture.client.ville }}{% endif %}
            </div>
            {% if facture.client.email or facture.client.telephone %}
            <div class="client-contact">
                {% if facture.client.email %}{{ facture.client.email }}<br>{% endif %}
                {% if facture.client.telephone %}{{ facture.client.telephone }}{% endif %}
            </div>
            {% endif %}
        </div>
    </div>
    <div class="bloc-spacer"></div>
    <div class="bloc-infos">
        <div class="bloc-titre">Informations</div>
        <div class="bloc-content">
            <table class="infos-table">
                <tr>
                    <td class="td-label">Référence</td>
                    <td class="td-value">{{ facture.numero }}</td>
                </tr>
                <tr>
                    <td class="td-label">Date d'émission</td>
                    <td>{{ facture.dateEmission|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td class="td-label">Mode de règlement</td>
                    <td>{{ facture.modeReglement.value }}</td>
                </tr>
                {% if facture.dossier %}
                <tr>
                    <td class="td-label">Dossier</td>
                    <td>{{ facture.dossier.titre|slice(0,35) }}</td>
                </tr>
                {% endif %}
                <tr>
                    <td class="td-label">Code client</td>
                    <td>{{ facture.client.codeClient }}</td>
                </tr>
            </table>
        </div>
    </div>
</div>

<!-- Lignes de facturation -->
{% if lignes|length > 0 %}
<table class="tableau-lignes">
    <thead>
        <tr>
            <th class="col-desc">Description</th>
            <th class="col-qty">Qté</th>
            <th class="col-unite">Unité</th>
            <th class="col-pu">Prix unit. HT</th>
            <th class="col-total">Total HT</th>
        </tr>
    </thead>
    <tbody>
        {% for ligne in lignes %}
        <tr>
            <td class="col-desc">{{ ligne.description }}</td>
            <td class="text-right">{{ ligne.quantite|number_format(2, ',', ' ') }}</td>
            <td class="text-right">{{ ligne.unite }}</td>
            <td class="text-right">{{ ligne.prixUnitaire|number_format(2, ',', ' ') }} €</td>
            <td class="text-right">{{ ligne.montantTotal|number_format(2, ',', ' ') }} €</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}

<!-- Totaux -->
<div class="totaux">
    <div class="totaux-left">
        {% if config.avocatNom %}
        <div class="reglement-bloc">
            <div class="reglement-titre">Avocat</div>
            {{ config.avocatNom }}<br>
            {% if config.avocatBarreau %}Barreau de {{ config.avocatBarreau }}<br>{% endif %}
            {% if config.avocatNumero %}N° {{ config.avocatNumero }}{% endif %}
        </div>
        {% endif %}
    </div>
    <div class="totaux-right">
        <table class="totaux-table">
            <tr>
                <td class="td-label">Montant HT</td>
                <td class="td-value">{{ facture.montantHt|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td class="td-label">TVA ({{ facture.tauxTva % 1 == 0 ? facture.tauxTva|number_format(0) : facture.tauxTva|number_format(2, ',', ' ') }} %)</td>
                <td class="td-value">{{ (facture.montantHt * facture.tauxTva / 100)|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr class="ligne-ttc">
                <td>Total TTC</td>
                <td class="td-value">{{ facture.montantTtc|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% if facture.provision > 0 %}
            <tr>
                <td class="td-label">Provision versée</td>
                <td class="td-green">- {{ facture.provision|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endif %}
            {% if montantPaye > 0 %}
            <tr>
                <td class="td-label">Paiements reçus</td>
                <td class="td-green">- {{ montantPaye|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endif %}
            {% if soldeRestant > 0 %}
            <tr class="ligne-solde">
                <td>Solde dû</td>
                <td class="td-value">{{ soldeRestant|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endif %}
        </table>
    </div>
</div>

<!-- Pied de page fixe -->
<div class="footer">
    <table class="footer-table">
        <tr>
            <td>{{ config.nom }}{% if config.siret %} — SIRET {{ config.siret }}{% endif %}</td>
            <td>{{ facture.numero }}</td>
            <td>Page <span class="pagenum"></span></td>
        </tr>
    </table>
</div>

</body>
</html>
